# daimon — AGNOS agent orchestrator
# Ported from 9724 lines of Rust
#
# Modules (in dependency order):
#   error     — error codes and HTTP status mapping
#   config    — service configuration
#   agent     — agent lifecycle, process spawning, /proc helpers
#   supervisor — circuit breaker, output capture, health monitoring, quotas
#   memory    — per-agent key-value store (filesystem-backed)
#   vector_store — in-memory cosine-similarity vector index
#   rag       — text chunking, bag-of-words embedding, retrieval pipeline
#   mcp       — MCP tool registry and dispatch types
#   screen    — capture permissions, rate limiting, recording sessions
#   scheduler — priority-aware task scheduling, cron triggers
#   federation — multi-node clustering, Raft-like election, placement
#   edge      — edge fleet management, heartbeats, OTA, GPU inventory
#   ipc       — Unix domain sockets, message bus, RPC
#   api       — HTTP REST API (port 8090)

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"
include "lib/json.cyr"
include "lib/net.cyr"
include "lib/args.cyr"
include "lib/chrono.cyr"
include "lib/sakshi.cyr"
include "lib/math.cyr"
include "lib/process.cyr"

# Syscall numbers not in stdlib
var SYS_RENAME = 82;
var SYS_SETSOCKOPT = 54;

# =========================================================================
# error — error codes and HTTP status mapping
# =========================================================================

enum DaimonError {
    ERR_NONE = 0;
    ERR_INVALID_PARAM = 1;
    ERR_AGENT_NOT_FOUND = 2;
    ERR_AGENT_EXISTS = 3;
    ERR_SUPERVISOR = 4;
    ERR_IPC = 5;
    ERR_SCHEDULER = 6;
    ERR_FEDERATION = 7;
    ERR_API = 8;
    ERR_STORAGE = 9;
    ERR_IO = 10;
}

# Map error code to HTTP status code
fn error_to_status(err) {
    if (err == ERR_INVALID_PARAM) { return 400; }
    if (err == ERR_AGENT_NOT_FOUND) { return 404; }
    if (err == ERR_AGENT_EXISTS) { return 409; }
    return 500;
}

# Format an error as JSON response body
# JSON key lookup using cstr comparison (avoids str_eq Str layout issues)
fn jget(pairs, key_cstr) {
    if (pairs == 0) { return 0; }
    var len = vec_len(pairs);
    var gi = 0;
    while (gi < len) {
        var p = vec_get(pairs, gi);
        var k = load64(p);  # key Str
        if (str_eq_cstr(k, key_cstr) == 1) {
            return load64(p + 8);  # value Str
        }
        gi = gi + 1;
    }
    return 0;
}

fn jget_int(pairs, key_cstr) {
    var v = jget(pairs, key_cstr);
    if (v == 0) { return 0; }
    return str_to_int(v);
}

fn error_json(code, msg) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"error\":\"");
    str_builder_add(sb, msg);
    str_builder_add_cstr(sb, "\",\"code\":");
    str_builder_add_int(sb, code);
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

# =========================================================================
# config — service configuration
# =========================================================================

# Config: {listen_addr: Str, port: i64, data_dir: Str, max_agents: i64}
# Layout: 4 fields x 8 bytes = 32 bytes

fn config_new() {
    var c = alloc(32);
    store64(c, str_from("127.0.0.1"));     # listen_addr
    store64(c + 8, 8090);                   # port
    store64(c + 16, str_from("/var/lib/agnos")); # data_dir
    store64(c + 24, 1000);                  # max_agents
    return c;
}

fn config_listen_addr(c) { return load64(c); }
fn config_port(c) { return load64(c + 8); }
fn config_data_dir(c) { return load64(c + 16); }
fn config_max_agents(c) { return load64(c + 24); }

fn config_set_port(c, port) { store64(c + 8, port); }
fn config_set_data_dir(c, dir) { store64(c + 16, dir); }
fn config_set_max_agents(c, n) { store64(c + 24, n); }

# =========================================================================
# agent — agent lifecycle, process spawning, /proc helpers
# =========================================================================

enum AgentStatus {
    AGENT_PENDING = 0;
    AGENT_STARTING = 1;
    AGENT_RUNNING = 2;
    AGENT_PAUSED = 3;
    AGENT_STOPPING = 4;
    AGENT_STOPPED = 5;
    AGENT_FAILED = 6;
}

enum StopReason {
    STOP_USER = 0;
    STOP_ERROR = 1;
    STOP_RESOURCE = 2;
    STOP_TIMEOUT = 3;
    STOP_PREEMPTED = 4;
}

# AgentHandle: {id, name, status, created_at, started_at, pid,
#               mem_used, cpu_time, fds_used, threads_used}
# 10 fields x 8 bytes = 80 bytes

fn agent_handle_new(id, name) {
    var h = alloc(80);
    store64(h, id);                # id (integer counter)
    store64(h + 8, name);          # name: Str
    store64(h + 16, AGENT_PENDING); # status
    store64(h + 24, clock_epoch_secs());   # created_at (epoch secs)
    store64(h + 32, 0);            # started_at
    store64(h + 40, 0);            # pid
    store64(h + 48, 0);            # mem_used
    store64(h + 56, 0);            # cpu_time
    store64(h + 64, 0);            # fds_used
    store64(h + 72, 0);            # threads_used
    return h;
}

fn agent_id(h) { return load64(h); }
fn agent_name(h) { return load64(h + 8); }
fn agent_status(h) { return load64(h + 16); }
fn agent_created_at(h) { return load64(h + 24); }
fn agent_started_at(h) { return load64(h + 32); }
fn agent_pid(h) { return load64(h + 40); }
fn agent_mem_used(h) { return load64(h + 48); }
fn agent_cpu_time(h) { return load64(h + 56); }
fn agent_fds_used(h) { return load64(h + 64); }
fn agent_threads(h) { return load64(h + 72); }

fn agent_set_status(h, s) { store64(h + 16, s); }
fn agent_set_pid(h, pid) { store64(h + 40, pid); }
fn agent_set_started_at(h, t) { store64(h + 32, t); }

# Global agent ID counter
var _next_agent_id = 1;

fn agent_next_id() {
    var id = _next_agent_id;
    _next_agent_id = _next_agent_id + 1;
    return id;
}

# /proc helpers — read resource usage for a PID

fn read_vm_rss(pid) {
    if (pid == 0) { return 0; }
    var path_sb = str_builder_new();
    str_builder_add_cstr(path_sb, "/proc/");
    str_builder_add_int(path_sb, pid);
    str_builder_add_cstr(path_sb, "/status");
    var path = str_builder_build(path_sb);

    var buf = alloc(8192);
    var n = file_read_all(str_data(path), buf, 8191);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);

    # Search for "VmRSS:" line
    var i = 0;
    while (i < n) {
        if (memeq(buf + i, "VmRSS:", 6) == 1) {
            var j = i + 6;
            # Skip whitespace
            while (j < n) {
                if (load8(buf + j) != 32) { break; }
                if (load8(buf + j) != 9) { break; }
                j = j + 1;
            }
            # Parse number (in kB)
            var kb = 0;
            while (j < n) {
                var c = load8(buf + j);
                if (c < 48) { break; }
                if (c > 57) { break; }
                kb = kb * 10 + c - 48;
                j = j + 1;
            }
            return kb * 1024;
        }
        # Advance to next line
        while (i < n) {
            if (load8(buf + i) == 10) { i = i + 1; break; }
            i = i + 1;
        }
    }
    return 0;
}

fn count_fds(pid) {
    if (pid == 0) { return 0; }
    var path_sb = str_builder_new();
    str_builder_add_cstr(path_sb, "/proc/");
    str_builder_add_int(path_sb, pid);
    str_builder_add_cstr(path_sb, "/fd");
    var path = str_builder_build(path_sb);
    var entries = dir_list(str_data(path));
    if (entries == 0) { return 0; }
    return vec_len(entries);
}

fn count_threads(pid) {
    if (pid == 0) { return 1; }
    var path_sb = str_builder_new();
    str_builder_add_cstr(path_sb, "/proc/");
    str_builder_add_int(path_sb, pid);
    str_builder_add_cstr(path_sb, "/task");
    var path = str_builder_build(path_sb);
    var entries = dir_list(str_data(path));
    if (entries == 0) { return 1; }
    var n = vec_len(entries);
    if (n == 0) { return 1; }
    return n;
}

# Update resource usage for an agent from /proc
fn agent_update_resources(h) {
    var pid = agent_pid(h);
    if (pid == 0) { return 0; }
    store64(h + 48, read_vm_rss(pid));
    store64(h + 64, count_fds(pid));
    store64(h + 72, count_threads(pid));
}

# Check if agent process is alive (kill -0)
fn agent_is_alive(h) {
    var pid = agent_pid(h);
    if (pid == 0) { return 0; }
    var r = syscall(SYS_KILL, pid, 0);
    if (r == 0) { return 1; }
    return 0;
}

# Start an agent process
fn agent_start(h, executable) {
    var status = agent_status(h);
    if (status != AGENT_PENDING) {
        if (status != AGENT_STOPPED) {
            return Err(ERR_SUPERVISOR);
        }
    }
    agent_set_status(h, AGENT_STARTING);

    var name = agent_name(h);
    var id = agent_id(h);

    var id_str_sb = str_builder_new();
    str_builder_add_int(id_str_sb, id);
    var id_str = str_builder_build(id_str_sb);

    sakshi_info("starting agent");

    var pid_result = spawn(str_data(executable), str_data(id_str), str_data(name));
    if (is_err_result(pid_result) == 1) {
        agent_set_status(h, AGENT_FAILED);
        return Err(ERR_SUPERVISOR);
    }
    var pid = payload(pid_result);
    agent_set_pid(h, pid);
    agent_set_started_at(h, clock_epoch_secs());
    agent_set_status(h, AGENT_RUNNING);
    return Ok(pid);
}

# Stop an agent (SIGTERM then SIGKILL)
fn agent_stop(h, reason) {
    agent_set_status(h, AGENT_STOPPING);
    var pid = agent_pid(h);
    if (pid > 0) {
        # Send SIGTERM
        syscall(SYS_KILL, pid, 15);
        # Wait briefly, then force kill if needed
        var status_buf[1];
        var wr = syscall(SYS_WAIT4, pid, &status_buf, 1, 0);  # WNOHANG
        if (wr == 0) {
            # Process still running after WNOHANG, force kill
            syscall(SYS_KILL, pid, 9);
            syscall(SYS_WAIT4, pid, &status_buf, 0, 0);
        }
    }
    agent_set_status(h, AGENT_STOPPED);
    return Ok(0);
}

# Pause (SIGSTOP)
fn agent_pause(h) {
    if (agent_status(h) != AGENT_RUNNING) { return Err(ERR_SUPERVISOR); }
    var pid = agent_pid(h);
    if (pid > 0) { syscall(SYS_KILL, pid, 19); }  # SIGSTOP
    agent_set_status(h, AGENT_PAUSED);
    return Ok(0);
}

# Resume (SIGCONT)
fn agent_resume(h) {
    if (agent_status(h) != AGENT_PAUSED) { return Err(ERR_SUPERVISOR); }
    var pid = agent_pid(h);
    if (pid > 0) { syscall(SYS_KILL, pid, 18); }  # SIGCONT
    agent_set_status(h, AGENT_RUNNING);
    return Ok(0);
}

# =========================================================================
# supervisor — circuit breaker, output capture, health, quotas
# =========================================================================

enum CircuitState {
    CB_CLOSED = 0;
    CB_OPEN = 1;
    CB_HALF_OPEN = 2;
}

# CircuitBreaker: {state, failure_count, success_count,
#                  failure_threshold, recovery_timeout_ms, half_open_max,
#                  last_failure_time}
# 7 fields x 8 = 56 bytes

fn cb_new(threshold, timeout_ms, half_open_max) {
    var cb = alloc(56);
    store64(cb, CB_CLOSED);
    store64(cb + 8, 0);               # failure_count
    store64(cb + 16, 0);              # success_count
    store64(cb + 24, threshold);
    store64(cb + 32, timeout_ms);
    store64(cb + 40, half_open_max);
    store64(cb + 48, 0);              # last_failure_time
    return cb;
}

fn cb_default() { return cb_new(5, 30000, 3); }

fn cb_state(cb) { return load64(cb); }
fn cb_failure_count(cb) { return load64(cb + 8); }

fn cb_record_success(cb) {
    var state = load64(cb);
    if (state == CB_HALF_OPEN) {
        var sc = load64(cb + 16) + 1;
        store64(cb + 16, sc);
        if (sc >= load64(cb + 40)) {
            store64(cb, CB_CLOSED);
            store64(cb + 8, 0);
            store64(cb + 16, 0);
        }
    }
    elif (state == CB_CLOSED) {
        store64(cb + 8, 0);
    }
}

fn cb_record_failure(cb) {
    var fc = load64(cb + 8) + 1;
    store64(cb + 8, fc);
    store64(cb + 48, clock_epoch_secs());
    var state = load64(cb);
    if (state == CB_CLOSED) {
        if (fc >= load64(cb + 24)) {
            store64(cb, CB_OPEN);
            sakshi_warn("circuit breaker opened");
        }
    }
    elif (state == CB_HALF_OPEN) {
        store64(cb, CB_OPEN);
        store64(cb + 16, 0);
    }
}

fn cb_can_execute(cb) {
    var state = load64(cb);
    if (state == CB_CLOSED) { return 1; }
    if (state == CB_HALF_OPEN) { return 1; }
    # CB_OPEN — check recovery timeout
    var last = load64(cb + 48);
    if (last > 0) {
        var elapsed_ms = (clock_epoch_secs() - last) * 1000;
        if (elapsed_ms >= load64(cb + 32)) {
            store64(cb, CB_HALF_OPEN);
            store64(cb + 16, 0);
            return 1;
        }
    }
    return 0;
}

fn cb_reset(cb) {
    store64(cb, CB_CLOSED);
    store64(cb + 8, 0);
    store64(cb + 16, 0);
    store64(cb + 48, 0);
}

# OutputCapture — ring buffer for stdout/stderr lines
# OutputLine: {timestamp: Str, stream: i64 (0=stdout, 1=stderr), content: Str}
# 3 fields x 8 = 24 bytes

enum OutputStream {
    OUT_STDOUT = 0;
    OUT_STDERR = 1;
}

fn output_line_new(stream, content) {
    var ol = alloc(24);
    store64(ol, str_from_int(clock_epoch_secs()));
    store64(ol + 8, stream);
    store64(ol + 16, content);
    return ol;
}

# OutputCapture: {lines: vec, max_lines: i64}
# 2 fields x 8 = 16 bytes

fn output_capture_new(max_lines) {
    var oc = alloc(16);
    store64(oc, vec_new());
    store64(oc + 8, max_lines);
    return oc;
}

fn output_capture_push(oc, stream, content) {
    var lines = load64(oc);
    var max = load64(oc + 8);
    if (vec_len(lines) >= max) {
        vec_remove(lines, 0);
    }
    vec_push(lines, output_line_new(stream, content));
}

fn output_capture_len(oc) { return vec_len(load64(oc)); }

fn output_capture_tail(oc, n) {
    var lines = load64(oc);
    var total = vec_len(lines);
    var result = vec_new();
    var start = total - n;
    if (start < 0) { start = 0; }
    var i = start;
    while (i < total) {
        vec_push(result, vec_get(lines, i));
        i = i + 1;
    }
    return result;
}

fn output_capture_clear(oc) {
    store64(oc, vec_new());
}

# ResourceQuota: {mem_warn_pct, mem_kill_pct, cpu_throttle_pct,
#                  mem_limit, cpu_time_limit}
# Pct values stored as integer basis points (8000 = 80.00%)
# 5 fields x 8 = 40 bytes

fn quota_new(mem_limit, cpu_time_limit) {
    var q = alloc(40);
    store64(q, 8000);              # mem_warn_pct (80%)
    store64(q + 8, 9500);          # mem_kill_pct (95%)
    store64(q + 16, 9000);         # cpu_throttle_pct (90%)
    store64(q + 24, mem_limit);
    store64(q + 32, cpu_time_limit);
    return q;
}

fn quota_default() {
    return quota_new(1073741824, 3600000);  # 1 GiB, 1 hour ms
}

fn quota_mem_limit(q) { return load64(q + 24); }
fn quota_cpu_time_limit(q) { return load64(q + 32); }

# AgentHealth: {agent_id, is_healthy, consecutive_failures,
#               consecutive_successes, last_check_time, last_response_ms,
#               mem_used, cpu_time, fds, threads}
# 10 fields x 8 = 80 bytes

fn agent_health_new(aid) {
    var ah = alloc(80);
    store64(ah, aid);
    store64(ah + 8, 1);       # is_healthy
    store64(ah + 16, 0);      # consecutive_failures
    store64(ah + 24, 0);      # consecutive_successes
    store64(ah + 32, clock_epoch_secs());
    store64(ah + 40, 0);      # last_response_ms
    store64(ah + 48, 0);      # mem_used
    store64(ah + 56, 0);      # cpu_time
    store64(ah + 64, 0);      # fds
    store64(ah + 72, 0);      # threads
    return ah;
}

fn health_agent_id(ah) { return load64(ah); }
fn health_is_healthy(ah) { return load64(ah + 8); }
fn health_failures(ah) { return load64(ah + 16); }
fn health_successes(ah) { return load64(ah + 24); }

# HealthCheckConfig: {interval_secs, timeout_secs, unhealthy_threshold,
#                      healthy_threshold}
# 4 fields x 8 = 32 bytes

fn hc_config_default() {
    var hc = alloc(32);
    store64(hc, 30);    # interval_secs
    store64(hc + 8, 5);  # timeout_secs
    store64(hc + 16, 3); # unhealthy_threshold
    store64(hc + 24, 2); # healthy_threshold
    return hc;
}

# Supervisor: {health_map, quota_map, breaker_map, hc_config}
# 4 fields x 8 = 32 bytes

fn supervisor_new() {
    var sup = alloc(32);
    store64(sup, map_new());      # health_map: agent_id_str -> AgentHealth
    store64(sup + 8, map_new());  # quota_map: agent_id_str -> ResourceQuota
    store64(sup + 16, map_new()); # breaker_map: agent_id_str -> CircuitBreaker
    store64(sup + 24, hc_config_default());
    return sup;
}

fn supervisor_register(sup, agent_id_str) {
    var hmap = load64(sup);
    var qmap = load64(sup + 8);
    var bmap = load64(sup + 16);

    var id_cstr = str_data(agent_id_str);
    map_set(hmap, id_cstr, agent_health_new(0));
    map_set(qmap, id_cstr, quota_default());
    map_set(bmap, id_cstr, cb_default());
}

fn supervisor_unregister(sup, agent_id_str) {
    var id_cstr = str_data(agent_id_str);
    map_delete(load64(sup), id_cstr);
    map_delete(load64(sup + 8), id_cstr);
    map_delete(load64(sup + 16), id_cstr);
}

# =========================================================================
# memory — per-agent key-value store
# =========================================================================

var MAX_KEY_LENGTH = 256;
var MAX_VALUE_SIZE = 1048576;

# Validate a memory key
fn validate_key(key) {
    var klen = str_len(key);
    if (klen == 0) { return Err(ERR_INVALID_PARAM); }
    if (klen > MAX_KEY_LENGTH) { return Err(ERR_INVALID_PARAM); }

    # Check for path traversal
    if (str_contains(key, str_from("..")) == 1) { return Err(ERR_INVALID_PARAM); }
    if (str_contains(key, str_from("/")) == 1) { return Err(ERR_INVALID_PARAM); }
    if (str_contains(key, str_from("\\")) == 1) { return Err(ERR_INVALID_PARAM); }
    return Ok(0);
}

# Sanitize a key for use as filename — replace non-alnum with underscore
fn sanitize_key(key) {
    var data = str_data(key);
    var klen = str_len(key);
    var buf = alloc(klen + 1);
    var i = 0;
    while (i < klen) {
        var c = load8(data + i);
        # Allow a-z, A-Z, 0-9, - _ .
        if (c >= 97) {
            if (c <= 122) { store8(buf + i, c); i = i + 1; continue; }
        }
        if (c >= 65) {
            if (c <= 90) { store8(buf + i, c); i = i + 1; continue; }
        }
        if (c >= 48) {
            if (c <= 57) { store8(buf + i, c); i = i + 1; continue; }
        }
        if (c == 45) { store8(buf + i, c); i = i + 1; continue; }  # -
        if (c == 95) { store8(buf + i, c); i = i + 1; continue; }  # _
        if (c == 46) { store8(buf + i, c); i = i + 1; continue; }  # .
        store8(buf + i, 95);  # Replace with _
        i = i + 1;
    }
    store8(buf + klen, 0);
    return str_new(buf, klen);
}

# MemoryStore: {base_dir: Str}
fn memory_store_new(base_dir) {
    var ms = alloc(8);
    store64(ms, base_dir);
    return ms;
}

fn memory_store_agent_dir(ms, agent_id_str) {
    return path_join(str_data(load64(ms)), str_data(agent_id_str));
}

fn memory_store_set(ms, agent_id_str, key, value_json) {
    var vr = validate_key(key);
    if (is_err_result(vr) == 1) { return vr; }

    var dir = memory_store_agent_dir(ms, agent_id_str);
    # Ensure directory exists
    syscall(SYS_MKDIR, str_data(dir), 493);  # 0755

    var safe_key = sanitize_key(key);
    var fname = str_cat(safe_key, str_from(".json"));
    var fpath = path_join(str_data(dir), str_data(fname));

    # Build JSON entry
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"key\":\"");
    str_builder_add(sb, key);
    str_builder_add_cstr(sb, "\",\"value\":");
    str_builder_add(sb, value_json);
    str_builder_add_cstr(sb, ",\"updated_at\":");
    str_builder_add_int(sb, clock_epoch_secs());
    str_builder_add_cstr(sb, "}");
    var content = str_builder_build(sb);

    # Atomic write: tmp then rename
    var tmp_path = str_cat(fpath, str_from(".tmp"));
    file_write_all(str_data(tmp_path), str_data(content), str_len(content));
    syscall(SYS_RENAME, str_data(tmp_path), str_data(fpath));

    return Ok(0);
}

fn memory_store_get(ms, agent_id_str, key) {
    var dir = memory_store_agent_dir(ms, agent_id_str);
    var safe_key = sanitize_key(key);
    var fname = str_cat(safe_key, str_from(".json"));
    var fpath = path_join(str_data(dir), str_data(fname));

    var buf = alloc(MAX_VALUE_SIZE);
    var n = file_read_all(str_data(fpath), buf, MAX_VALUE_SIZE - 1);
    if (n <= 0) { return None(); }
    store8(buf + n, 0);
    return Some(str_new(buf, n));
}

fn memory_store_delete(ms, agent_id_str, key) {
    var dir = memory_store_agent_dir(ms, agent_id_str);
    var safe_key = sanitize_key(key);
    var fname = str_cat(safe_key, str_from(".json"));
    var fpath = path_join(str_data(dir), str_data(fname));

    var r = syscall(SYS_UNLINK, str_data(fpath));
    if (r == 0) { return Ok(1); }
    return Ok(0);
}

fn memory_store_list_keys(ms, agent_id_str) {
    var dir = memory_store_agent_dir(ms, agent_id_str);
    var entries = dir_list(str_data(dir));
    if (entries == 0) { return vec_new(); }
    var keys = vec_new();
    var i = 0;
    while (i < vec_len(entries)) {
        var name = vec_get(entries, i);
        # Check .json extension
        var name_s = str_from(name);
        if (str_ends_with(name_s, str_from(".json")) == 1) {
            # Strip .json suffix (5 chars)
            var stem = str_sub(name_s, 0, str_len(name_s) - 5);
            vec_push(keys, stem);
        }
        i = i + 1;
    }
    return keys;
}

fn memory_store_clear(ms, agent_id_str) {
    var dir = memory_store_agent_dir(ms, agent_id_str);
    var entries = dir_list(str_data(dir));
    if (entries == 0) { return 0; }
    var count = 0;
    var i = 0;
    while (i < vec_len(entries)) {
        var name = vec_get(entries, i);
        var name_s = str_from(name);
        if (str_ends_with(name_s, str_from(".json")) == 1) {
            var fpath = path_join(str_data(dir), name);
            syscall(SYS_UNLINK, str_data(fpath));
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

# =========================================================================
# vector_store — in-memory cosine-similarity search
# =========================================================================

# Cosine similarity between two f64 arrays of equal length
fn cosine_similarity(a, b, dim) {
    if (dim == 0) { return 0; }
    var dot = f64_from(0);
    var norm_a = f64_from(0);
    var norm_b = f64_from(0);
    var i = 0;
    while (i < dim) {
        var x = load64(a + i * 8);
        var y = load64(b + i * 8);
        dot = f64_add(dot, f64_mul(x, y));
        norm_a = f64_add(norm_a, f64_mul(x, x));
        norm_b = f64_add(norm_b, f64_mul(y, y));
        i = i + 1;
    }
    var denom = f64_mul(f64_sqrt(norm_a), f64_sqrt(norm_b));
    if (f64_eq(denom, f64_from(0)) == 1) { return f64_from(0); }
    return f64_div(dot, denom);
}

# VectorEntry: {id, embedding_ptr, embedding_dim, content: Str, metadata: Str, created_at}
# 6 fields x 8 = 48 bytes

fn vec_entry_new(id, embedding, dim, content, metadata) {
    var ve = alloc(48);
    store64(ve, id);
    store64(ve + 8, embedding);
    store64(ve + 16, dim);
    store64(ve + 24, content);
    store64(ve + 32, metadata);
    store64(ve + 40, clock_epoch_secs());
    return ve;
}

fn vec_entry_id(ve) { return load64(ve); }
fn vec_entry_embedding(ve) { return load64(ve + 8); }
fn vec_entry_dim(ve) { return load64(ve + 16); }
fn vec_entry_content(ve) { return load64(ve + 24); }
fn vec_entry_metadata(ve) { return load64(ve + 32); }

# SearchResult: {id, content: Str, metadata: Str, score (f64), rank}
# 5 fields x 8 = 40 bytes

fn search_result_new(id, content, metadata, score, rank) {
    var sr = alloc(40);
    store64(sr, id);
    store64(sr + 8, content);
    store64(sr + 16, metadata);
    store64(sr + 24, score);
    store64(sr + 32, rank);
    return sr;
}

fn search_result_content(sr) { return load64(sr + 8); }
fn search_result_score(sr) { return load64(sr + 24); }
fn search_result_rank(sr) { return load64(sr + 32); }

# VectorIndex: {entries: vec of VectorEntry, dimension: i64}
# 2 fields x 8 = 16 bytes

fn vindex_new() {
    var vi = alloc(16);
    store64(vi, vec_new());
    store64(vi + 8, 0);  # dimension (0 = not set)
    return vi;
}

fn vindex_len(vi) { return vec_len(load64(vi)); }
fn vindex_dimension(vi) { return load64(vi + 8); }

fn vindex_insert(vi, entry) {
    var dim = vec_entry_dim(entry);
    if (dim == 0) { return Err(ERR_INVALID_PARAM); }

    var idx_dim = load64(vi + 8);
    if (idx_dim == 0) {
        store64(vi + 8, dim);
    }
    elif (idx_dim != dim) {
        return Err(ERR_INVALID_PARAM);
    }

    vec_push(load64(vi), entry);
    return Ok(vec_entry_id(entry));
}

fn vindex_search(vi, query, query_dim, top_k) {
    var entries = load64(vi);
    var n = vec_len(entries);
    if (n == 0) { return vec_new(); }
    if (top_k == 0) { return vec_new(); }
    if (query_dim == 0) { return vec_new(); }

    # Score all entries
    var scored = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        var score = cosine_similarity(query, vec_entry_embedding(e), query_dim);
        # Store (score, entry) pair — pack into a 16-byte struct
        var pair = alloc(16);
        store64(pair, score);
        store64(pair + 8, e);
        vec_push(scored, pair);
        i = i + 1;
    }

    # Sort by score descending (simple insertion sort for moderate sizes)
    var sn = vec_len(scored);
    var si = 1;
    while (si < sn) {
        var key = vec_get(scored, si);
        var key_score = load64(key);
        var sj = si - 1;
        while (sj >= 0) {
            var cmp_score = load64(vec_get(scored, sj));
            if (f64_gt(cmp_score, key_score) == 1) { break; }
            vec_set(scored, sj + 1, vec_get(scored, sj));
            sj = sj - 1;
        }
        vec_set(scored, sj + 1, key);
        si = si + 1;
    }

    # Take top_k
    var results = vec_new();
    var ri = 0;
    while (ri < top_k) {
        if (ri >= sn) { break; }
        var pair = vec_get(scored, ri);
        var e = load64(pair + 8);
        var sr = search_result_new(
            vec_entry_id(e),
            vec_entry_content(e),
            vec_entry_metadata(e),
            load64(pair),
            ri
        );
        vec_push(results, sr);
        ri = ri + 1;
    }
    return results;
}

fn vindex_remove(vi, target_id) {
    var entries = load64(vi);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (vec_entry_id(e) == target_id) {
            vec_remove(entries, i);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# =========================================================================
# rag — text chunking, bag-of-words embedding, retrieval pipeline
# =========================================================================

# RagConfig: {top_k, chunk_size, overlap, min_relevance_score (f64),
#              context_template: Str}
# 5 fields x 8 = 40 bytes

fn rag_config_default() {
    var rc = alloc(40);
    store64(rc, 5);                # top_k
    store64(rc + 8, 512);          # chunk_size
    store64(rc + 16, 64);          # overlap
    store64(rc + 24, f64_from(0)); # min_relevance (0.1 not easily representable, use 0)
    store64(rc + 32, str_from("Use the following context to answer the question.\n\n---\n{context}\n---\n\nQuestion: {query}"));
    return rc;
}

fn rag_top_k(rc) { return load64(rc); }
fn rag_chunk_size(rc) { return load64(rc + 8); }

# Chunk text into pieces of at most chunk_size chars with overlap
fn chunk_text(text, chunk_size, overlap) {
    var chunks = vec_new();
    var tlen = str_len(text);
    if (tlen == 0) { return chunks; }
    if (chunk_size == 0) { return chunks; }

    if (overlap >= chunk_size) { overlap = chunk_size - 1; }
    var step = chunk_size - overlap;
    if (step == 0) { step = 1; }

    var pos = 0;
    while (pos < tlen) {
        var end = pos + chunk_size;
        if (end > tlen) { end = tlen; }
        var chunk = str_sub(text, pos, end - pos);
        vec_push(chunks, chunk);
        pos = pos + step;
    }
    return chunks;
}

# Simple tokenize: split on non-alnum, lowercase
fn tokenize(text) {
    var tokens = vec_new();
    var data = str_data(text);
    var tlen = str_len(text);
    var start = 0;
    var i = 0;
    while (i <= tlen) {
        var c = 0;
        if (i < tlen) { c = load8(data + i); }
        var is_alnum = 0;
        if (c >= 97) { if (c <= 122) { is_alnum = 1; } }
        if (c >= 65) { if (c <= 90) { is_alnum = 1; } }
        if (c >= 48) { if (c <= 57) { is_alnum = 1; } }

        if (is_alnum == 0) {
            if (i > start) {
                # Extract token and lowercase it
                var tok_len = i - start;
                var tok_buf = alloc(tok_len + 1);
                var j = 0;
                while (j < tok_len) {
                    var tc = load8(data + start + j);
                    # Lowercase A-Z
                    if (tc >= 65) { if (tc <= 90) { tc = tc + 32; } }
                    store8(tok_buf + j, tc);
                    j = j + 1;
                }
                store8(tok_buf + tok_len, 0);
                vec_push(tokens, str_new(tok_buf, tok_len));
            }
            start = i + 1;
        }
        i = i + 1;
    }
    return tokens;
}

# RagPipeline: {index: VectorIndex, config: RagConfig, next_id}
# 3 fields x 8 = 24 bytes

fn rag_pipeline_new(config) {
    var rp = alloc(24);
    store64(rp, vindex_new());
    store64(rp + 8, config);
    store64(rp + 16, 1);  # next_id counter
    return rp;
}

fn rag_pipeline_index(rp) { return load64(rp); }
fn rag_pipeline_config(rp) { return load64(rp + 8); }

# Ingest text: chunk, create simple embeddings, insert into index
fn rag_ingest_text(rp, text, metadata) {
    var config = load64(rp + 8);
    var cs = load64(config + 8);   # chunk_size
    var ov = load64(config + 16);  # overlap
    var chunks = chunk_text(text, cs, ov);
    if (vec_len(chunks) == 0) { return vec_new(); }

    var ids = vec_new();
    var ci = 0;
    while (ci < vec_len(chunks)) {
        var chunk = vec_get(chunks, ci);
        # Simple bag-of-words embedding: tokenize + count
        var toks = tokenize(chunk);
        var ntoks = vec_len(toks);
        if (ntoks == 0) { ci = ci + 1; continue; }

        # Create a simple embedding based on token hashes
        var dim = 32;
        var emb = alloc(dim * 8);
        var ei = 0;
        while (ei < dim) { store64(emb + ei * 8, f64_from(0)); ei = ei + 1; }

        var ti = 0;
        while (ti < ntoks) {
            var tok = vec_get(toks, ti);
            # Simple hash: sum of char values mod dim
            var hash = 0;
            var td = str_data(tok);
            var tl = str_len(tok);
            var hi = 0;
            while (hi < tl) {
                hash = hash + load8(td + hi);
                hi = hi + 1;
            }
            var slot = hash % dim;
            var cur = load64(emb + slot * 8);
            store64(emb + slot * 8, f64_add(cur, f64_from(1)));
            ti = ti + 1;
        }

        var id = load64(rp + 16);
        store64(rp + 16, id + 1);
        var entry = vec_entry_new(id, emb, dim, chunk, metadata);
        vindex_insert(load64(rp), entry);
        vec_push(ids, id);
        ci = ci + 1;
    }
    return ids;
}

# Query the pipeline: embed query, search, format context
fn rag_query_text(rp, query) {
    var config = load64(rp + 8);
    var top_k = load64(config);
    var idx = load64(rp);

    # Embed query same way as ingest
    var toks = tokenize(query);
    var ntoks = vec_len(toks);
    var dim = 32;
    var qemb = alloc(dim * 8);
    var ei = 0;
    while (ei < dim) { store64(qemb + ei * 8, f64_from(0)); ei = ei + 1; }

    var ti = 0;
    while (ti < ntoks) {
        var tok = vec_get(toks, ti);
        var hash = 0;
        var td = str_data(tok);
        var tl = str_len(tok);
        var hi = 0;
        while (hi < tl) { hash = hash + load8(td + hi); hi = hi + 1; }
        var slot = hash % dim;
        var cur = load64(qemb + slot * 8);
        store64(qemb + slot * 8, f64_add(cur, f64_from(1)));
        ti = ti + 1;
    }

    var results = vindex_search(idx, qemb, dim, top_k);

    # Format context
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Use the following context to answer the question.\n\n---\n");
    var ri = 0;
    while (ri < vec_len(results)) {
        var sr = vec_get(results, ri);
        str_builder_add_cstr(sb, "[");
        str_builder_add_int(sb, ri + 1);
        str_builder_add_cstr(sb, "] ");
        str_builder_add(sb, search_result_content(sr));
        str_builder_add_cstr(sb, "\n\n");
        ri = ri + 1;
    }
    str_builder_add_cstr(sb, "---\n\nQuestion: ");
    str_builder_add(sb, query);
    return str_builder_build(sb);
}

# =========================================================================
# mcp — MCP tool registry (standalone types, no bote dependency)
# =========================================================================

# McpToolDescription: {name: Str, description: Str, input_schema: Str}
# 3 fields x 8 = 24 bytes

fn mcp_tool_new(name, desc, schema) {
    var t = alloc(24);
    store64(t, name);
    store64(t + 8, desc);
    store64(t + 16, schema);
    return t;
}

fn mcp_tool_name(t) { return load64(t); }
fn mcp_tool_desc(t) { return load64(t + 8); }

# McpToolResult: {content: Str, is_error: i64}
fn mcp_result_text(text) {
    var r = alloc(16);
    store64(r, text);
    store64(r + 8, 0);
    return r;
}

fn mcp_result_error(msg) {
    var r = alloc(16);
    store64(r, msg);
    store64(r + 8, 1);
    return r;
}

# McpHostRegistry: {builtin: map, external: map}
fn mcp_registry_new() {
    var reg = alloc(16);
    store64(reg, map_new());     # builtin: name_cstr -> McpToolDescription
    store64(reg + 8, map_new()); # external: name_cstr -> McpToolDescription
    return reg;
}

fn mcp_register_builtin(reg, tool) {
    var name = mcp_tool_name(tool);
    map_set(load64(reg), str_cstr(name), tool);
}

fn mcp_register_external(reg, tool, callback_url) {
    var name = mcp_tool_name(tool);
    var ext = alloc(16);
    store64(ext, tool);
    store64(ext + 8, callback_url);
    map_set(load64(reg + 8), str_cstr(name), ext);
}

fn mcp_tool_count(reg) {
    return map_count(load64(reg)) + map_count(load64(reg + 8));
}

fn mcp_find_tool(reg, name_cstr) {
    var t = map_get(load64(reg), name_cstr);
    if (t != 0) { return t; }
    var ext = map_get(load64(reg + 8), name_cstr);
    if (ext != 0) { return load64(ext); }
    return 0;
}

fn mcp_deregister(reg, name_cstr) {
    return map_delete(load64(reg + 8), name_cstr);
}

# =========================================================================
# screen — capture permissions, rate limiting, recording sessions
# =========================================================================

enum CaptureTarget {
    CAP_FULLSCREEN = 0;
    CAP_WINDOW = 1;
    CAP_REGION = 2;
}

enum RecordingStatus {
    REC_ACTIVE = 0;
    REC_PAUSED = 1;
    REC_STOPPED = 2;
}

# RecordingSession: {id: Str, status, frame_count, started_at, agent_id: Str}
# 5 fields x 8 = 40 bytes

fn recording_session_new(agent_id) {
    var s = alloc(40);
    store64(s, str_from_int(_next_agent_id)); # reuse counter for unique IDs
    _next_agent_id = _next_agent_id + 1;
    store64(s + 8, REC_ACTIVE);
    store64(s + 16, 0);            # frame_count
    store64(s + 24, clock_epoch_secs());
    store64(s + 32, agent_id);
    return s;
}

fn recording_id(s) { return load64(s); }
fn recording_status(s) { return load64(s + 8); }
fn recording_frame_count(s) { return load64(s + 16); }

fn recording_add_frame(s) {
    if (load64(s + 8) != REC_ACTIVE) { return Err(ERR_INVALID_PARAM); }
    var fc = load64(s + 16) + 1;
    store64(s + 16, fc);
    return Ok(fc);
}

fn recording_pause(s) {
    if (load64(s + 8) != REC_ACTIVE) { return Err(ERR_INVALID_PARAM); }
    store64(s + 8, REC_PAUSED);
    return Ok(0);
}

fn recording_resume(s) {
    if (load64(s + 8) != REC_PAUSED) { return Err(ERR_INVALID_PARAM); }
    store64(s + 8, REC_ACTIVE);
    return Ok(0);
}

fn recording_stop(s) {
    store64(s + 8, REC_STOPPED);
    return Ok(0);
}

# RecordingManager: {sessions: map<id_cstr, RecordingSession>}
fn rec_mgr_new() {
    var rm = alloc(8);
    store64(rm, map_new());
    return rm;
}

fn rec_mgr_start(rm, agent_id) {
    var s = recording_session_new(agent_id);
    var id = recording_id(s);
    map_set(load64(rm), str_data(id), s);
    return id;
}

fn rec_mgr_get(rm, id_cstr) {
    return map_get(load64(rm), id_cstr);
}

# CapturePermission: {agent_id: Str, max_per_minute, expires_at,
#                      rate_timestamps: vec}
# 4 fields x 8 = 32 bytes

fn cap_perm_new(agent_id, max_per_minute) {
    var cp = alloc(32);
    store64(cp, agent_id);
    store64(cp + 8, max_per_minute);
    store64(cp + 16, 0);           # expires_at (0 = never)
    store64(cp + 24, vec_new());   # rate_timestamps
    return cp;
}

# CapturePermissionManager: {permissions: map<agent_id_cstr, CapturePermission>}
fn cap_mgr_new() {
    var cm = alloc(8);
    store64(cm, map_new());
    return cm;
}

fn cap_mgr_grant(cm, perm) {
    var aid = load64(perm);
    map_set(load64(cm), str_data(aid), perm);
}

fn cap_mgr_revoke(cm, agent_id_cstr) {
    map_delete(load64(cm), agent_id_cstr);
}

fn cap_mgr_check(cm, agent_id_cstr) {
    var perm = map_get(load64(cm), agent_id_cstr);
    if (perm == 0) { return Err(ERR_INVALID_PARAM); }

    # Check expiry
    var expires = load64(perm + 16);
    if (expires > 0) {
        if (clock_epoch_secs() > expires) { return Err(ERR_INVALID_PARAM); }
    }

    # Check rate limit
    var timestamps = load64(perm + 24);
    var now = clock_epoch_secs();
    # Remove entries older than 60 seconds
    var new_ts = vec_new();
    var i = 0;
    while (i < vec_len(timestamps)) {
        var t = vec_get(timestamps, i);
        if (now - t < 60) { vec_push(new_ts, t); }
        i = i + 1;
    }
    store64(perm + 24, new_ts);

    var max = load64(perm + 8);
    if (vec_len(new_ts) >= max) { return Err(ERR_INVALID_PARAM); }

    vec_push(new_ts, now);
    return Ok(0);
}

# =========================================================================
# scheduler — priority-aware task scheduling
# =========================================================================

enum TaskStatus {
    TASK_QUEUED = 0;
    TASK_SCHEDULED = 1;
    TASK_RUNNING = 2;
    TASK_COMPLETED = 3;
    TASK_FAILED = 4;
    TASK_CANCELLED = 5;
    TASK_PREEMPTED = 6;
}

enum TaskPriority {
    PRIO_NORMAL = 0;
    PRIO_HIGH = 1;
    PRIO_CRITICAL = 2;
    PRIO_EMERGENCY = 3;
}

fn priority_from_numeric(p) {
    if (p <= 3) { return PRIO_NORMAL; }
    if (p <= 6) { return PRIO_HIGH; }
    if (p <= 9) { return PRIO_CRITICAL; }
    return PRIO_EMERGENCY;
}

# ScheduledTask: {task_id: Str, name: Str, description: Str, agent_id: Str,
#                  priority, status, created_at, cpu_cores, memory_mb}
# 9 fields x 8 = 72 bytes

fn sched_task_new(name, desc, agent_id, priority) {
    var t = alloc(72);
    var tid = str_from_int(_next_agent_id);
    _next_agent_id = _next_agent_id + 1;
    store64(t, tid);
    store64(t + 8, name);
    store64(t + 16, desc);
    store64(t + 24, agent_id);
    # Clamp priority 1-10
    if (priority < 1) { priority = 1; }
    if (priority > 10) { priority = 10; }
    store64(t + 32, priority);
    store64(t + 40, TASK_QUEUED);
    store64(t + 48, clock_epoch_secs());
    store64(t + 56, 1);    # cpu_cores (integer)
    store64(t + 64, 256);  # memory_mb
    return t;
}

fn sched_task_id(t) { return load64(t); }
fn sched_task_name(t) { return load64(t + 8); }
fn sched_task_priority(t) { return load64(t + 32); }
fn sched_task_status(t) { return load64(t + 40); }
fn sched_task_set_status(t, s) { store64(t + 40, s); }

fn sched_task_transition(t, new_status) {
    var from = load64(t + 40);
    # Validate transition
    var valid = 0;
    if (from == TASK_QUEUED) {
        if (new_status == TASK_SCHEDULED) { valid = 1; }
        if (new_status == TASK_CANCELLED) { valid = 1; }
    }
    if (from == TASK_SCHEDULED) {
        if (new_status == TASK_RUNNING) { valid = 1; }
        if (new_status == TASK_CANCELLED) { valid = 1; }
        if (new_status == TASK_QUEUED) { valid = 1; }
    }
    if (from == TASK_RUNNING) {
        if (new_status == TASK_COMPLETED) { valid = 1; }
        if (new_status == TASK_FAILED) { valid = 1; }
        if (new_status == TASK_CANCELLED) { valid = 1; }
        if (new_status == TASK_PREEMPTED) { valid = 1; }
    }
    if (from == TASK_PREEMPTED) {
        if (new_status == TASK_QUEUED) { valid = 1; }
    }
    if (valid == 0) { return Err(ERR_SCHEDULER); }
    store64(t + 40, new_status);
    return Ok(0);
}

# NodeCapacity: {node_id: Str, total_cpu, avail_cpu, total_mem, avail_mem,
#                 total_disk, avail_disk, gpu_available, tpu_available,
#                 tpu_chips, running_tasks}
# 11 fields x 8 = 88 bytes

fn node_cap_new(node_id, total_cpu, total_mem, total_disk, gpu) {
    var nc = alloc(88);
    store64(nc, node_id);
    store64(nc + 8, total_cpu);
    store64(nc + 16, total_cpu);      # avail_cpu = total initially
    store64(nc + 24, total_mem);
    store64(nc + 32, total_mem);      # avail_mem = total
    store64(nc + 40, total_disk);
    store64(nc + 48, total_disk);     # avail_disk = total
    store64(nc + 56, gpu);
    store64(nc + 64, 0);              # tpu_available
    store64(nc + 72, 0);              # tpu_chips
    store64(nc + 80, 0);              # running_tasks
    return nc;
}

fn node_cap_id(nc) { return load64(nc); }
fn node_cap_avail_cpu(nc) { return load64(nc + 16); }
fn node_cap_avail_mem(nc) { return load64(nc + 32); }

fn node_cap_can_fit(nc, cpu, mem, disk) {
    if (load64(nc + 16) < cpu) { return 0; }
    if (load64(nc + 32) < mem) { return 0; }
    if (load64(nc + 48) < disk) { return 0; }
    return 1;
}

fn node_cap_utilization(nc) {
    var total_cpu = load64(nc + 8);
    var total_mem = load64(nc + 24);
    if (total_cpu == 0) {
        if (total_mem == 0) { return 0; }
    }
    var cpu_util = 0;
    if (total_cpu > 0) {
        cpu_util = 100 - (load64(nc + 16) * 100 / total_cpu);
    }
    var mem_util = 0;
    if (total_mem > 0) {
        mem_util = 100 - (load64(nc + 32) * 100 / total_mem);
    }
    return (cpu_util + mem_util) / 2;
}

fn node_cap_reserve(nc, cpu, mem, disk) {
    var ac = load64(nc + 16) - cpu;
    if (ac < 0) { ac = 0; }
    store64(nc + 16, ac);
    var am = load64(nc + 32) - mem;
    if (am < 0) { am = 0; }
    store64(nc + 32, am);
    var ad = load64(nc + 48) - disk;
    if (ad < 0) { ad = 0; }
    store64(nc + 48, ad);
    store64(nc + 80, load64(nc + 80) + 1);
}

fn node_cap_release(nc, cpu, mem, disk) {
    var ac = load64(nc + 16) + cpu;
    if (ac > load64(nc + 8)) { ac = load64(nc + 8); }
    store64(nc + 16, ac);
    var am = load64(nc + 32) + mem;
    if (am > load64(nc + 24)) { am = load64(nc + 24); }
    store64(nc + 32, am);
    var ad = load64(nc + 48) + disk;
    if (ad > load64(nc + 40)) { ad = load64(nc + 40); }
    store64(nc + 48, ad);
    var rt = load64(nc + 80) - 1;
    if (rt < 0) { rt = 0; }
    store64(nc + 80, rt);
}

# TaskScheduler: {tasks: map, nodes: map}
# 2 fields x 8 = 16 bytes
fn task_scheduler_new() {
    var ts = alloc(16);
    store64(ts, map_new());       # tasks: id_cstr -> ScheduledTask
    store64(ts + 8, map_new());   # nodes: id_cstr -> NodeCapacity
    return ts;
}

fn scheduler_register_node(ts, nc) {
    map_set(load64(ts + 8), str_data(node_cap_id(nc)), nc);
}

fn scheduler_submit(ts, task) {
    var id = sched_task_id(task);
    map_set(load64(ts), str_data(id), task);
    return Ok(id);
}

fn scheduler_get(ts, id_cstr) {
    return map_get(load64(ts), id_cstr);
}

fn scheduler_cancel(ts, id_cstr) {
    var task = map_get(load64(ts), id_cstr);
    if (task == 0) { return Err(ERR_SCHEDULER); }
    return sched_task_transition(task, TASK_CANCELLED);
}

# Get pending tasks sorted by priority desc, created_at asc
fn scheduler_pending_tasks(ts) {
    var tasks = load64(ts);
    var keys = map_keys(tasks);
    var pending = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var t = map_get(tasks, vec_get(keys, i));
        if (sched_task_status(t) == TASK_QUEUED) { vec_push(pending, t); }
        i = i + 1;
    }
    # Sort by priority desc (insertion sort)
    var n = vec_len(pending);
    i = 1;
    while (i < n) {
        var key = vec_get(pending, i);
        var kp = sched_task_priority(key);
        var j = i - 1;
        while (j >= 0) {
            var jp = sched_task_priority(vec_get(pending, j));
            if (jp >= kp) { break; }
            vec_set(pending, j + 1, vec_get(pending, j));
            j = j - 1;
        }
        vec_set(pending, j + 1, key);
        i = i + 1;
    }
    return pending;
}

# Find the best-fit node (lowest utilization that can fit the resource req)
fn scheduler_best_fit(ts, cpu, mem, disk) {
    var nodes = load64(ts + 8);
    var keys = map_keys(nodes);
    var best_id = 0;
    var best_util = 101;  # Higher than max (100)
    var i = 0;
    while (i < vec_len(keys)) {
        var nc = map_get(nodes, vec_get(keys, i));
        if (node_cap_can_fit(nc, cpu, mem, disk) == 1) {
            var util = node_cap_utilization(nc);
            if (util < best_util) {
                best_util = util;
                best_id = node_cap_id(nc);
            }
        }
        i = i + 1;
    }
    return best_id;
}

# Schedule all pending tasks — returns vec of decisions (as JSON strings)
fn scheduler_schedule_pending(ts) {
    var pending = scheduler_pending_tasks(ts);
    var decisions = vec_new();
    var nodes = load64(ts + 8);
    var tasks = load64(ts);
    var i = 0;
    while (i < vec_len(pending)) {
        var task = vec_get(pending, i);
        var cpu = load64(task + 56);
        var mem = load64(task + 64);
        var node_id = scheduler_best_fit(ts, cpu, mem, 0);
        if (node_id != 0) {
            var nc = map_get(nodes, str_data(node_id));
            if (nc != 0) { node_cap_reserve(nc, cpu, mem, 0); }
            sched_task_transition(task, TASK_SCHEDULED);
            # Build decision JSON
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "{\"task_id\":\"");
            str_builder_add(sb, sched_task_id(task));
            str_builder_add_cstr(sb, "\",\"assigned_node\":\"");
            str_builder_add(sb, node_id);
            str_builder_add_cstr(sb, "\",\"reason\":\"best-fit\"}");
            vec_push(decisions, str_builder_build(sb));
        }
        i = i + 1;
    }
    return decisions;
}

# Compute scheduler statistics
fn scheduler_stats(ts) {
    var tasks = load64(ts);
    var keys = map_keys(tasks);
    var total = vec_len(keys);
    var queued = 0;
    var running = 0;
    var completed = 0;
    var failed = 0;
    var i = 0;
    while (i < total) {
        var t = map_get(tasks, vec_get(keys, i));
        var s = sched_task_status(t);
        if (s == TASK_QUEUED) { queued = queued + 1; }
        elif (s == TASK_SCHEDULED) { queued = queued + 1; }
        elif (s == TASK_PREEMPTED) { queued = queued + 1; }
        elif (s == TASK_RUNNING) { running = running + 1; }
        elif (s == TASK_COMPLETED) { completed = completed + 1; }
        elif (s == TASK_CANCELLED) { completed = completed + 1; }
        elif (s == TASK_FAILED) { failed = failed + 1; }
        i = i + 1;
    }
    # Return packed stats: {total, queued, running, completed, failed}
    var st = alloc(40);
    store64(st, total);
    store64(st + 8, queued);
    store64(st + 16, running);
    store64(st + 24, completed);
    store64(st + 32, failed);
    return st;
}

# CronEntry: {name: Str, interval_secs, specific_hour, specific_minute,
#              task_name: Str, task_agent_id: Str, task_priority,
#              enabled, last_fired}
# 9 fields x 8 = 72 bytes

fn cron_entry_new(name, interval_secs, task_name, task_agent_id, task_priority) {
    var ce = alloc(72);
    store64(ce, name);
    store64(ce + 8, interval_secs);
    store64(ce + 16, 0 - 1);          # specific_hour (-1 = any)
    store64(ce + 24, 0 - 1);          # specific_minute (-1 = any)
    store64(ce + 32, task_name);
    store64(ce + 40, task_agent_id);
    store64(ce + 48, task_priority);
    store64(ce + 56, 1);              # enabled
    store64(ce + 64, 0);              # last_fired
    return ce;
}

fn cron_entry_name(ce) { return load64(ce); }
fn cron_entry_enabled(ce) { return load64(ce + 56); }
fn cron_entry_set_enabled(ce, e) { store64(ce + 56, e); }

# CronScheduler: {entries: map<name_cstr, CronEntry>}
fn cron_scheduler_new() {
    var cs = alloc(8);
    store64(cs, map_new());
    return cs;
}

fn cron_add_entry(cs, entry) {
    var name = cron_entry_name(entry);
    if (str_len(name) == 0) { return Err(ERR_SCHEDULER); }
    # Validate hour/minute if specified
    var hour = load64(entry + 16);
    if (hour >= 0) {
        if (hour > 23) { return Err(ERR_SCHEDULER); }
    }
    var minute = load64(entry + 24);
    if (minute >= 0) {
        if (minute > 59) { return Err(ERR_SCHEDULER); }
    }
    map_set(load64(cs), str_data(name), entry);
    return Ok(0);
}

fn cron_remove_entry(cs, name_cstr) {
    return map_delete(load64(cs), name_cstr);
}

# Check which entries should fire now, return vec of task templates
fn cron_check_fires(cs) {
    var entries = load64(cs);
    var keys = map_keys(entries);
    var now = clock_epoch_secs();
    var fired = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var entry = map_get(entries, vec_get(keys, i));
        if (load64(entry + 56) == 0) { i = i + 1; continue; }  # disabled
        var last = load64(entry + 64);
        var interval = load64(entry + 8);
        if (interval > 0) {
            if (now - last >= interval) {
                store64(entry + 64, now);  # update last_fired
                vec_push(fired, entry);
            }
        }
        i = i + 1;
    }
    return fired;
}

fn cron_entry_count(cs) { return map_count(load64(cs)); }

# =========================================================================
# federation — multi-node clustering (types + placement scoring)
# =========================================================================

enum NodeRole {
    ROLE_COORDINATOR = 0;
    ROLE_FOLLOWER = 1;
    ROLE_CANDIDATE = 2;
}

enum FedNodeStatus {
    FED_ONLINE = 0;
    FED_SUSPECT = 1;
    FED_DEAD = 2;
}

enum SchedulingStrategy {
    SCHED_BALANCED = 0;
    SCHED_PACKED = 1;
    SCHED_SPREAD = 2;
}

# FederationNode: {node_id: Str, name: Str, role, status,
#                   last_heartbeat, current_term, voted_for: Str,
#                   cpu_cores, memory_mb, gpu_count}
# 10 fields x 8 = 80 bytes

fn fed_node_new(name, cpu_cores, memory_mb, gpu_count) {
    var n = alloc(80);
    var nid = str_from_int(_next_agent_id);
    _next_agent_id = _next_agent_id + 1;
    store64(n, nid);
    store64(n + 8, name);
    store64(n + 16, ROLE_FOLLOWER);
    store64(n + 24, FED_ONLINE);
    store64(n + 32, clock_epoch_secs());
    store64(n + 40, 0);           # current_term
    store64(n + 48, 0);           # voted_for
    store64(n + 56, cpu_cores);
    store64(n + 64, memory_mb);
    store64(n + 72, gpu_count);
    return n;
}

fn fed_node_id(n) { return load64(n); }
fn fed_node_name(n) { return load64(n + 8); }
fn fed_node_role(n) { return load64(n + 16); }
fn fed_node_status(n) { return load64(n + 24); }
fn fed_node_set_role(n, r) { store64(n + 16, r); }
fn fed_node_set_status(n, s) { store64(n + 24, s); }
fn fed_node_update_heartbeat(n) { store64(n + 32, clock_epoch_secs()); }

# FederationManager: {nodes: map<id_cstr, FederationNode>, strategy}
fn fed_mgr_new(strategy) {
    var fm = alloc(16);
    store64(fm, map_new());
    store64(fm + 8, strategy);
    return fm;
}

fn fed_mgr_add_node(fm, node) {
    map_set(load64(fm), str_data(fed_node_id(node)), node);
}

fn fed_mgr_remove_node(fm, id_cstr) {
    return map_delete(load64(fm), id_cstr);
}

fn fed_mgr_get_node(fm, id_cstr) {
    return map_get(load64(fm), id_cstr);
}

fn fed_mgr_node_count(fm) { return map_count(load64(fm)); }

fn fed_mgr_record_heartbeat(fm, id_cstr) {
    var node = map_get(load64(fm), id_cstr);
    if (node == 0) { return Err(ERR_FEDERATION); }
    store64(node + 32, clock_epoch_secs());
    store64(node + 24, FED_ONLINE);
    return Ok(0);
}

# Check health of all nodes based on heartbeat age
fn fed_mgr_check_health(fm, suspect_secs, dead_secs) {
    var nodes = load64(fm);
    var keys = map_keys(nodes);
    var now = clock_epoch_secs();
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        var age = now - load64(node + 32);
        if (age > dead_secs) {
            if (load64(node + 24) != FED_DEAD) { store64(node + 24, FED_DEAD); }
        }
        elif (age > suspect_secs) {
            if (load64(node + 24) == FED_ONLINE) { store64(node + 24, FED_SUSPECT); }
        }
        i = i + 1;
    }
}

# Get nodes with ONLINE status
fn fed_mgr_live_nodes(fm) {
    var nodes = load64(fm);
    var keys = map_keys(nodes);
    var live = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        if (load64(node + 24) == FED_ONLINE) { vec_push(live, node); }
        i = i + 1;
    }
    return live;
}

# Start election — local node becomes candidate, increments term
fn fed_mgr_start_election(fm, local_id_cstr) {
    var node = map_get(load64(fm), local_id_cstr);
    if (node == 0) { return Err(ERR_FEDERATION); }
    store64(node + 16, ROLE_CANDIDATE);
    var term = load64(node + 40) + 1;
    store64(node + 40, term);
    store64(node + 48, fed_node_id(node));  # voted_for = self
    return Ok(term);
}

# Become coordinator
fn fed_mgr_become_coordinator(fm, id_cstr) {
    var node = map_get(load64(fm), id_cstr);
    if (node == 0) { return Err(ERR_FEDERATION); }
    store64(node + 16, ROLE_COORDINATOR);
    return Ok(0);
}

# Node scorer — weighted 4-factor placement scoring
# Score = 0.4*resource_headroom + 0.3*locality + 0.2*load_balance + 0.1*affinity
fn fed_score_node(node, req_cpu, req_mem, preferred_id, max_load, node_load) {
    var cpu_cores = load64(node + 56);
    var memory_mb = load64(node + 64);

    # Resource headroom (40%)
    var cpu_head = 100;
    if (req_cpu > 0) {
        if (cpu_cores > 0) {
            cpu_head = (cpu_cores - req_cpu) * 100 / cpu_cores;
            if (cpu_head < 0) { cpu_head = 0; }
        }
        else { cpu_head = 0; }
    }
    var mem_head = 100;
    if (req_mem > 0) {
        if (memory_mb > 0) {
            mem_head = (memory_mb - req_mem) * 100 / memory_mb;
            if (mem_head < 0) { mem_head = 0; }
        }
        else { mem_head = 0; }
    }
    var resource = (cpu_head + mem_head) / 2;

    # Locality (30%)
    var locality = 0;
    if (preferred_id != 0) {
        if (str_eq(fed_node_id(node), preferred_id) == 1) { locality = 100; }
    }

    # Load balance (20%)
    var load_bal = 100;
    if (max_load > 0) {
        load_bal = 100 - (node_load * 100 / max_load);
    }

    # Total: weighted sum (integer, 0-100 scale)
    return resource * 40 / 100 + locality * 30 / 100 + load_bal * 20 / 100;
}

fn fed_mgr_stats(fm) {
    var nodes = load64(fm);
    var keys = map_keys(nodes);
    var total = vec_len(keys);
    var live = 0;
    var suspect = 0;
    var dead = 0;
    var i = 0;
    while (i < total) {
        var n = map_get(nodes, vec_get(keys, i));
        var s = load64(n + 24);
        if (s == FED_ONLINE) { live = live + 1; }
        elif (s == FED_SUSPECT) { suspect = suspect + 1; }
        elif (s == FED_DEAD) { dead = dead + 1; }
        i = i + 1;
    }
    var st = alloc(32);
    store64(st, total);
    store64(st + 8, live);
    store64(st + 16, suspect);
    store64(st + 24, dead);
    return st;
}

# =========================================================================
# edge — edge fleet management
# =========================================================================

enum EdgeStatus {
    EDGE_ONLINE = 0;
    EDGE_SUSPECT = 1;
    EDGE_OFFLINE = 2;
    EDGE_UPDATING = 3;
    EDGE_DECOMMISSIONED = 4;
}

# EdgeNode: {id: Str, name: Str, status, arch: Str, cpu_cores,
#             memory_mb, disk_mb, has_gpu, last_heartbeat,
#             active_tasks, tasks_completed, agent_version: Str}
# 12 fields x 8 = 96 bytes

fn edge_node_new(name, arch, cpu_cores, memory_mb) {
    var n = alloc(96);
    var nid = str_from_int(_next_agent_id);
    _next_agent_id = _next_agent_id + 1;
    store64(n, nid);
    store64(n + 8, name);
    store64(n + 16, EDGE_ONLINE);
    store64(n + 24, arch);
    store64(n + 32, cpu_cores);
    store64(n + 40, memory_mb);
    store64(n + 48, 32768);       # disk_mb default
    store64(n + 56, 0);           # has_gpu
    store64(n + 64, clock_epoch_secs());  # last_heartbeat
    store64(n + 72, 0);           # active_tasks
    store64(n + 80, 0);           # tasks_completed
    store64(n + 88, str_from("0.0.0"));  # agent_version
    return n;
}

fn edge_node_id(n) { return load64(n); }
fn edge_node_name(n) { return load64(n + 8); }
fn edge_node_status(n) { return load64(n + 16); }
fn edge_node_set_status(n, s) { store64(n + 16, s); }
fn edge_node_active_tasks(n) { return load64(n + 72); }
fn edge_node_tasks_completed(n) { return load64(n + 80); }

fn edge_node_heartbeat(n, active, completed) {
    store64(n + 64, clock_epoch_secs());
    store64(n + 72, active);
    store64(n + 80, completed);
}

# EdgeFleetConfig: {suspect_secs, offline_secs, max_nodes, require_tpm}
fn edge_fleet_config_default() {
    var c = alloc(32);
    store64(c, 30);     # suspect_threshold_secs
    store64(c + 8, 90); # offline_threshold_secs
    store64(c + 16, 1000);
    store64(c + 24, 0);  # require_tpm = false
    return c;
}

# EdgeFleetManager: {config, nodes: map<id_cstr, EdgeNode>}
fn edge_fleet_new(config) {
    var ef = alloc(16);
    store64(ef, config);
    store64(ef + 8, map_new());
    return ef;
}

fn edge_fleet_register(ef, node) {
    var nodes = load64(ef + 8);
    var config = load64(ef);
    var max_nodes = load64(config + 16);
    if (map_count(nodes) >= max_nodes) { return Err(ERR_INVALID_PARAM); }

    # Check for empty name
    var name = load64(node + 8);
    if (str_len(name) == 0) { return Err(ERR_INVALID_PARAM); }

    # Check for duplicate name
    var keys = map_keys(nodes);
    var di = 0;
    while (di < vec_len(keys)) {
        var existing = map_get(nodes, vec_get(keys, di));
        if (str_eq(load64(existing + 8), name) == 1) { return Err(ERR_INVALID_PARAM); }
        di = di + 1;
    }

    map_set(nodes, str_cstr(edge_node_id(node)), node);
    return Ok(edge_node_id(node));
}

fn edge_fleet_get(ef, id_cstr) {
    return map_get(load64(ef + 8), id_cstr);
}

fn edge_fleet_node_count(ef) { return map_count(load64(ef + 8)); }

fn edge_fleet_heartbeat(ef, id_cstr, active_tasks, tasks_completed) {
    var node = map_get(load64(ef + 8), id_cstr);
    if (node == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    if (edge_node_status(node) == EDGE_DECOMMISSIONED) { return Err(ERR_INVALID_PARAM); }
    store64(node + 64, clock_epoch_secs());
    edge_node_set_status(node, EDGE_ONLINE);
    store64(node + 72, active_tasks);
    store64(node + 80, tasks_completed);
    return Ok(0);
}

fn edge_fleet_check_health(ef) {
    var nodes = load64(ef + 8);
    var config = load64(ef);
    var suspect_secs = load64(config);
    var offline_secs = load64(config + 8);
    var now = clock_epoch_secs();
    var keys = map_keys(nodes);
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        var s = edge_node_status(node);
        if (s == EDGE_DECOMMISSIONED) { i = i + 1; continue; }
        if (s == EDGE_UPDATING) { i = i + 1; continue; }
        var age = now - load64(node + 64);
        if (age > offline_secs) {
            if (s != EDGE_OFFLINE) { edge_node_set_status(node, EDGE_OFFLINE); }
        }
        elif (age > suspect_secs) {
            if (s == EDGE_ONLINE) { edge_node_set_status(node, EDGE_SUSPECT); }
        }
        i = i + 1;
    }
}

fn edge_fleet_decommission(ef, id_cstr) {
    var node = map_get(load64(ef + 8), id_cstr);
    if (node == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    edge_node_set_status(node, EDGE_DECOMMISSIONED);
    return Ok(0);
}

fn edge_fleet_list(ef, status_filter) {
    var nodes = load64(ef + 8);
    var keys = map_keys(nodes);
    var result = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        if (status_filter < 0) {
            vec_push(result, node);
        }
        elif (edge_node_status(node) == status_filter) {
            vec_push(result, node);
        }
        i = i + 1;
    }
    return result;
}

fn edge_fleet_stats(ef) {
    var nodes = load64(ef + 8);
    var keys = map_keys(nodes);
    var total = vec_len(keys);
    var online = 0;
    var suspect = 0;
    var offline = 0;
    var updating = 0;
    var decomm = 0;
    var active = 0;
    var completed = 0;
    var i = 0;
    while (i < total) {
        var n = map_get(nodes, vec_get(keys, i));
        var s = edge_node_status(n);
        if (s == EDGE_ONLINE) { online = online + 1; }
        elif (s == EDGE_SUSPECT) { suspect = suspect + 1; }
        elif (s == EDGE_OFFLINE) { offline = offline + 1; }
        elif (s == EDGE_UPDATING) { updating = updating + 1; }
        elif (s == EDGE_DECOMMISSIONED) { decomm = decomm + 1; }
        active = active + edge_node_active_tasks(n);
        completed = completed + edge_node_tasks_completed(n);
        i = i + 1;
    }
    # Return stats as 8 packed fields
    var st = alloc(64);
    store64(st, total);
    store64(st + 8, online);
    store64(st + 16, suspect);
    store64(st + 24, offline);
    store64(st + 32, updating);
    store64(st + 40, decomm);
    store64(st + 48, active);
    store64(st + 56, completed);
    return st;
}

# =========================================================================
# ipc — message types (sync version, no async runtime)
# =========================================================================

# IpcMessage: {id: Str, source: Str, target: Str, msg_type, payload: Str,
#               timestamp}
# 6 fields x 8 = 48 bytes

enum MessageType {
    MSG_REQUEST = 0;
    MSG_RESPONSE = 1;
    MSG_EVENT = 2;
    MSG_HEARTBEAT = 3;
    MSG_COMMAND = 4;
}

var MAX_MESSAGE_SIZE = 65536;

fn ipc_msg_new(source, target, msg_type, payload) {
    var m = alloc(48);
    store64(m, str_from_int(_next_agent_id));
    _next_agent_id = _next_agent_id + 1;
    store64(m + 8, source);
    store64(m + 16, target);
    store64(m + 24, msg_type);
    store64(m + 32, payload);
    store64(m + 40, clock_epoch_secs());
    return m;
}

fn ipc_msg_source(m) { return load64(m + 8); }
fn ipc_msg_target(m) { return load64(m + 16); }
fn ipc_msg_type(m) { return load64(m + 24); }
fn ipc_msg_payload(m) { return load64(m + 32); }

# MessageBus: {subscribers: map<agent_id_cstr, queue_vec>,
#               agent_names: map<name_cstr, agent_id_cstr>}
fn msg_bus_new() {
    var mb = alloc(16);
    store64(mb, map_new());      # subscribers
    store64(mb + 8, map_new());  # agent_names
    return mb;
}

fn msg_bus_subscribe(mb, agent_id_cstr) {
    map_set(load64(mb), agent_id_cstr, vec_new());
}

fn msg_bus_unsubscribe(mb, agent_id_cstr) {
    map_delete(load64(mb), agent_id_cstr);
}

fn msg_bus_register_name(mb, name_cstr, agent_id_cstr) {
    map_set(load64(mb + 8), name_cstr, agent_id_cstr);
}

fn msg_bus_publish(mb, msg) {
    var target = ipc_msg_target(msg);
    var target_cstr = str_data(target);
    var subs = load64(mb);

    # Check if broadcast
    if (streq(target_cstr, "*") == 1) {
        var keys = map_keys(subs);
        var i = 0;
        while (i < vec_len(keys)) {
            var queue = map_get(subs, vec_get(keys, i));
            if (queue != 0) { vec_push(queue, msg); }
            i = i + 1;
        }
        return Ok(0);
    }

    # Named routing
    var names = load64(mb + 8);
    var resolved = map_get(names, target_cstr);
    if (resolved != 0) {
        var queue = map_get(subs, resolved);
        if (queue != 0) { vec_push(queue, msg); }
        return Ok(0);
    }

    # Direct ID routing
    var queue = map_get(subs, target_cstr);
    if (queue != 0) { vec_push(queue, msg); }
    return Ok(0);
}

fn msg_bus_send_to(mb, agent_id_cstr, msg) {
    var queue = map_get(load64(mb), agent_id_cstr);
    if (queue == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    vec_push(queue, msg);
    return Ok(0);
}

fn msg_bus_send_to_name(mb, name_cstr, msg) {
    var id = map_get(load64(mb + 8), name_cstr);
    if (id == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    return msg_bus_send_to(mb, id, msg);
}

fn msg_bus_get_agent_id(mb, name_cstr) {
    return map_get(load64(mb + 8), name_cstr);
}

# RpcRegistry: {methods: map<method_name_cstr, agent_id_cstr>}
fn rpc_registry_new() {
    var rr = alloc(8);
    store64(rr, map_new());
    return rr;
}

fn rpc_register_method(rr, method_cstr, agent_id_cstr) {
    map_set(load64(rr), method_cstr, agent_id_cstr);
}

fn rpc_find_handler(rr, method_cstr) {
    return map_get(load64(rr), method_cstr);
}

fn rpc_unregister_agent(rr, agent_id_cstr) {
    var methods = load64(rr);
    var keys = map_keys(methods);
    var i = 0;
    while (i < vec_len(keys)) {
        var handler = map_get(methods, vec_get(keys, i));
        if (handler == agent_id_cstr) { map_delete(methods, vec_get(keys, i)); }
        i = i + 1;
    }
}

fn rpc_list_methods(rr) {
    return map_keys(load64(rr));
}

