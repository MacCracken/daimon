    # =============================================================
    # FederatedVectorStore
    # =============================================================
    test_group("fed_vector_store");

    var fvs = fed_vstore_new(str_from("local-1"), REPL_FULL);
    assert_eq(fed_vstore_collection_count(fvs), 0, "empty store");
    assert(str_eq(fed_vstore_local_id(fvs), str_from("local-1")) == 1, "local id");
    assert_eq(fed_vstore_strategy(fvs), REPL_FULL, "strategy full");

    # Register replicas
    fed_vstore_register_replica(fvs, "docs", str_from("local-1"), str_from("127.0.0.1:8090"), 100);
    fed_vstore_register_replica(fvs, "docs", str_from("node-2"), str_from("10.0.0.2:8090"), 95);
    fed_vstore_register_replica(fvs, "logs", str_from("node-3"), str_from("10.0.0.3:8090"), 50);
    assert_eq(fed_vstore_collection_count(fvs), 2, "2 collections");

    # All replicas for docs
    var docs_all = fed_vstore_all_replicas(fvs, "docs");
    assert_eq(vec_len(docs_all), 2, "docs has 2 replicas");

    # Remote replicas (excludes local)
    var docs_remote = fed_vstore_remote_replicas(fvs, "docs");
    assert_eq(vec_len(docs_remote), 1, "docs has 1 remote");
    assert(str_eq(replica_node_id(vec_get(docs_remote, 0)), str_from("node-2")) == 1, "remote is node-2");

    # Collections list
    var fv_colls = fed_vstore_collections(fvs);
    assert_eq(vec_len(fv_colls), 2, "2 collection names");

    # Remove node
    fed_vstore_remove_node(fvs, str_from("node-2"));
    var docs_after = fed_vstore_all_replicas(fvs, "docs");
    assert_eq(vec_len(docs_after), 1, "docs down to 1 replica");
    var docs_remote2 = fed_vstore_remote_replicas(fvs, "docs");
    assert_eq(vec_len(docs_remote2), 0, "no remote replicas for docs");

    # Stats
    var fv_st = fed_vstore_stats(fvs);
    assert_eq(load64(fv_st), 2, "2 collections in stats");
    assert_eq(load64(fv_st + 8), 2, "2 total replicas");  # local-1 docs + node-3 logs

    # Merge results
    var local_res = vec_new();
    vec_push(local_res, remote_result_new(str_from("v1"), f64_from(90), str_from("doc1"), str_from("local")));
    vec_push(local_res, remote_result_new(str_from("v2"), f64_from(70), str_from("doc2"), str_from("local")));
    var remote_batch = vec_new();
    var rbatch1 = vec_new();
    vec_push(rbatch1, remote_result_new(str_from("v3"), f64_from(85), str_from("doc3"), str_from("node-2")));
    vec_push(rbatch1, remote_result_new(str_from("v1"), f64_from(80), str_from("doc1-dup"), str_from("node-2")));  # dup, lower score
    vec_push(remote_batch, rbatch1);

    var merged = fed_vstore_merge_results(fvs, local_res, remote_batch, 3);
    assert_eq(vec_len(merged), 3, "3 merged results");
    # First should be highest score (v1=90)
    assert(str_eq(remote_result_id(vec_get(merged, 0)), str_from("v1")) == 1, "top result is v1");
    # v1 should have score 90 (kept higher), not 80

    # =============================================================
    # Summary
    # =============================================================
    return assert_summary();
}

var r = main();
syscall(SYS_EXIT, r);
