# --- jget (cstr-based JSON lookup) ---

fn jget(pairs, key_cstr) {
    if (pairs == 0) { return 0; }
    var len = vec_len(pairs);
    var gi = 0;
    while (gi < len) {
        var p = vec_get(pairs, gi);
        var k = load64(p);
        if (str_eq_cstr(k, key_cstr) == 1) { return load64(p + 8); }
        gi = gi + 1;
    }
    return 0;
}

fn jget_int(pairs, key_cstr) {
    var v = jget(pairs, key_cstr);
    if (v == 0) { return 0; }
    return str_to_int(v);
}

# --- node capacity ---

fn node_cap_new(node_id, total_cpu, total_mem, total_disk, gpu) {
    var nc = alloc(88);
    store64(nc, node_id);
    store64(nc + 8, total_cpu);
    store64(nc + 16, total_cpu);
    store64(nc + 24, total_mem);
    store64(nc + 32, total_mem);
    store64(nc + 40, total_disk);
    store64(nc + 48, total_disk);
    store64(nc + 56, gpu);
    store64(nc + 64, 0);
    store64(nc + 72, 0);
    store64(nc + 80, 0);
    return nc;
}

fn node_cap_id(nc) { return load64(nc); }
fn node_cap_avail_cpu(nc) { return load64(nc + 16); }
fn node_cap_avail_mem(nc) { return load64(nc + 32); }

fn node_cap_can_fit(nc, cpu, mem, disk) {
    if (load64(nc + 16) < cpu) { return 0; }
    if (load64(nc + 32) < mem) { return 0; }
    if (load64(nc + 48) < disk) { return 0; }
    return 1;
}

fn node_cap_utilization(nc) {
    var total_cpu = load64(nc + 8);
    var total_mem = load64(nc + 24);
    if (total_cpu == 0) { if (total_mem == 0) { return 0; } }
    var cpu_util = 0;
    if (total_cpu > 0) { cpu_util = 100 - (load64(nc + 16) * 100 / total_cpu); }
    var mem_util = 0;
    if (total_mem > 0) { mem_util = 100 - (load64(nc + 32) * 100 / total_mem); }
    return (cpu_util + mem_util) / 2;
}

fn node_cap_reserve(nc, cpu, mem, disk) {
    var ac = load64(nc + 16) - cpu;
    if (ac < 0) { ac = 0; }
    store64(nc + 16, ac);
    var am = load64(nc + 32) - mem;
    if (am < 0) { am = 0; }
    store64(nc + 32, am);
    store64(nc + 80, load64(nc + 80) + 1);
}

fn node_cap_release(nc, cpu, mem, disk) {
    var ac = load64(nc + 16) + cpu;
    if (ac > load64(nc + 8)) { ac = load64(nc + 8); }
    store64(nc + 16, ac);
    var am = load64(nc + 32) + mem;
    if (am > load64(nc + 24)) { am = load64(nc + 24); }
    store64(nc + 32, am);
}

# --- scheduler task accessors ---

fn sched_task_new(name, desc, agent_id, priority) {
    var t = alloc(72);
    var tid = str_from_int(agent_next_id());
    store64(t, tid);
    store64(t + 8, name);
    store64(t + 16, desc);
    store64(t + 24, agent_id);
    if (priority < 1) { priority = 1; }
    if (priority > 10) { priority = 10; }
    store64(t + 32, priority);
    store64(t + 40, TASK_QUEUED);
    store64(t + 48, clock_epoch_secs());
    store64(t + 56, 1);
    store64(t + 64, 256);
    return t;
}

fn sched_task_id(t) { return load64(t); }
fn sched_task_name(t) { return load64(t + 8); }
fn sched_task_priority(t) { return load64(t + 32); }
fn sched_task_status(t) { return load64(t + 40); }
fn sched_task_set_status(t, s) { store64(t + 40, s); }

# --- scheduler (extended) ---

fn task_scheduler_new() {
    var ts = alloc(16);
    store64(ts, map_new());
    store64(ts + 8, map_new());
    return ts;
}

fn scheduler_register_node(ts, nc) {
    map_set(load64(ts + 8), str_cstr(node_cap_id(nc)), nc);
}

fn scheduler_submit(ts, task) {
    var id = sched_task_id(task);
    map_set(load64(ts), str_cstr(id), task);
    return Ok(id);
}

fn scheduler_pending_tasks(ts) {
    var tasks = load64(ts);
    var keys = map_keys(tasks);
    var pending = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var t = map_get(tasks, vec_get(keys, i));
        if (sched_task_status(t) == TASK_QUEUED) { vec_push(pending, t); }
        i = i + 1;
    }
    var n = vec_len(pending);
    i = 1;
    while (i < n) {
        var key = vec_get(pending, i);
        var kp = sched_task_priority(key);
        var j = i - 1;
        while (j >= 0) {
            var jp = sched_task_priority(vec_get(pending, j));
            if (jp >= kp) { break; }
            vec_set(pending, j + 1, vec_get(pending, j));
            j = j - 1;
        }
        vec_set(pending, j + 1, key);
        i = i + 1;
    }
    return pending;
}

fn scheduler_best_fit(ts, cpu, mem, disk) {
    var nodes = load64(ts + 8);
    var keys = map_keys(nodes);
    var best_id = 0;
    var best_util = 101;
    var i = 0;
    while (i < vec_len(keys)) {
        var nc = map_get(nodes, vec_get(keys, i));
        if (node_cap_can_fit(nc, cpu, mem, disk) == 1) {
            var util = node_cap_utilization(nc);
            if (util < best_util) { best_util = util; best_id = node_cap_id(nc); }
        }
        i = i + 1;
    }
    return best_id;
}

fn scheduler_schedule_pending(ts) {
    var pending = scheduler_pending_tasks(ts);
    var decisions = vec_new();
    var nodes = load64(ts + 8);
    var i = 0;
    while (i < vec_len(pending)) {
        var task = vec_get(pending, i);
        var cpu = load64(task + 56);
        var mem = load64(task + 64);
        var node_id = scheduler_best_fit(ts, cpu, mem, 0);
        if (node_id != 0) {
            var nc = map_get(nodes, str_cstr(node_id));
            if (nc != 0) { node_cap_reserve(nc, cpu, mem, 0); }
            sched_task_transition(task, TASK_SCHEDULED);
            vec_push(decisions, node_id);
        }
        i = i + 1;
    }
    return decisions;
}

fn scheduler_stats(ts) {
    var tasks = load64(ts);
    var keys = map_keys(tasks);
    var total = vec_len(keys);
    var queued = 0;
    var running = 0;
    var completed = 0;
    var failed = 0;
    var i = 0;
    while (i < total) {
        var t = map_get(tasks, vec_get(keys, i));
        var s = sched_task_status(t);
        if (s == TASK_QUEUED) { queued = queued + 1; }
        elif (s == TASK_SCHEDULED) { queued = queued + 1; }
        elif (s == TASK_RUNNING) { running = running + 1; }
        elif (s == TASK_COMPLETED) { completed = completed + 1; }
        elif (s == TASK_CANCELLED) { completed = completed + 1; }
        elif (s == TASK_FAILED) { failed = failed + 1; }
        i = i + 1;
    }
    var st = alloc(40);
    store64(st, total);
    store64(st + 8, queued);
    store64(st + 16, running);
    store64(st + 24, completed);
    store64(st + 32, failed);
    return st;
}

fn scheduler_get(ts, id_cstr) { return map_get(load64(ts), id_cstr); }
fn scheduler_cancel(ts, id_cstr) {
    var task = map_get(load64(ts), id_cstr);
    if (task == 0) { return Err(ERR_SCHEDULER); }
    return sched_task_transition(task, TASK_CANCELLED);
}

# --- cron scheduler ---

fn cron_entry_new(name, interval_secs, task_name, task_agent_id, task_priority) {
    var ce = alloc(72);
    store64(ce, name);
    store64(ce + 8, interval_secs);
    store64(ce + 16, 0 - 1);
    store64(ce + 24, 0 - 1);
    store64(ce + 32, task_name);
    store64(ce + 40, task_agent_id);
    store64(ce + 48, task_priority);
    store64(ce + 56, 1);
    store64(ce + 64, 0);
    return ce;
}

fn cron_scheduler_new() {
    var cs = alloc(8);
    store64(cs, map_new());
    return cs;
}

fn cron_add_entry(cs, entry) {
    var name = load64(entry);
    if (str_len(name) == 0) { return Err(ERR_SCHEDULER); }
    var hour = load64(entry + 16);
    if (hour >= 0) { if (hour > 23) { return Err(ERR_SCHEDULER); } }
    var minute = load64(entry + 24);
    if (minute >= 0) { if (minute > 59) { return Err(ERR_SCHEDULER); } }
    map_set(load64(cs), str_cstr(name), entry);
    return Ok(0);
}

fn cron_remove_entry(cs, name_cstr) { return map_delete(load64(cs), name_cstr); }
fn cron_entry_count(cs) { return map_count(load64(cs)); }

# --- federation enums + types ---

enum NodeRole { ROLE_COORDINATOR = 0; ROLE_FOLLOWER = 1; ROLE_CANDIDATE = 2; }
enum FedNodeStatus { FED_ONLINE = 0; FED_SUSPECT = 1; FED_DEAD = 2; }
enum SchedulingStrategy { SCHED_BALANCED = 0; SCHED_PACKED = 1; SCHED_SPREAD = 2; }

fn fed_node_new(name, cpu_cores, memory_mb, gpu_count) {
    var n = alloc(80);
    var nid = str_from_int(agent_next_id());
    store64(n, nid);
    store64(n + 8, name);
    store64(n + 16, ROLE_FOLLOWER);
    store64(n + 24, FED_ONLINE);
    store64(n + 32, clock_epoch_secs());
    store64(n + 40, 0);
    store64(n + 48, 0);
    store64(n + 56, cpu_cores);
    store64(n + 64, memory_mb);
    store64(n + 72, gpu_count);
    return n;
}

fn fed_node_id(n) { return load64(n); }
fn fed_node_role(n) { return load64(n + 16); }

fn fed_mgr_new(strategy) {
    var fm = alloc(16);
    store64(fm, map_new());
    store64(fm + 8, strategy);
    return fm;
}

fn fed_mgr_add_node(fm, node) { map_set(load64(fm), str_cstr(fed_node_id(node)), node); }
fn fed_mgr_node_count(fm) { return map_count(load64(fm)); }

fn fed_mgr_live_nodes(fm) {
    var nodes = load64(fm);
    var keys = map_keys(nodes);
    var live = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        if (load64(node + 24) == FED_ONLINE) { vec_push(live, node); }
        i = i + 1;
    }
    return live;
}

fn fed_mgr_start_election(fm, local_id_cstr) {
    var node = map_get(load64(fm), local_id_cstr);
    if (node == 0) { return Err(ERR_FEDERATION); }
    store64(node + 16, ROLE_CANDIDATE);
    var term = load64(node + 40) + 1;
    store64(node + 40, term);
    return Ok(term);
}

fn fed_mgr_become_coordinator(fm, id_cstr) {
    var node = map_get(load64(fm), id_cstr);
    if (node == 0) { return Err(ERR_FEDERATION); }
    store64(node + 16, ROLE_COORDINATOR);
    return Ok(0);
}

fn fed_score_node(node, req_cpu, req_mem, preferred_id, max_load, node_load) {
    var cpu_cores = load64(node + 56);
    var memory_mb = load64(node + 64);
    var cpu_head = 100;
    if (req_cpu > 0) {
        if (cpu_cores > 0) { cpu_head = (cpu_cores - req_cpu) * 100 / cpu_cores; if (cpu_head < 0) { cpu_head = 0; } }
        else { cpu_head = 0; }
    }
    var mem_head = 100;
    if (req_mem > 0) {
        if (memory_mb > 0) { mem_head = (memory_mb - req_mem) * 100 / memory_mb; if (mem_head < 0) { mem_head = 0; } }
        else { mem_head = 0; }
    }
    var resource = (cpu_head + mem_head) / 2;
    var load_bal = 100;
    if (max_load > 0) { load_bal = 100 - (node_load * 100 / max_load); }
    return resource * 40 / 100 + load_bal * 20 / 100;
}

# --- edge fleet (extended) ---

fn edge_fleet_new(config) {
    var ef = alloc(16);
    store64(ef, config);
    store64(ef + 8, map_new());
    return ef;
}

fn edge_fleet_config_default() {
    var c = alloc(32);
    store64(c, 30);
    store64(c + 8, 90);
    store64(c + 16, 1000);
    store64(c + 24, 0);
    return c;
}

fn edge_fleet_register(ef, node) {
    var nodes = load64(ef + 8);
    var config = load64(ef);
    var max_nodes = load64(config + 16);
    if (map_count(nodes) >= max_nodes) { return Err(ERR_INVALID_PARAM); }
    var name = load64(node + 8);
    if (str_len(name) == 0) { return Err(ERR_INVALID_PARAM); }
    var keys = map_keys(nodes);
    var di = 0;
    while (di < vec_len(keys)) {
        var existing = map_get(nodes, vec_get(keys, di));
        if (str_eq(load64(existing + 8), name) == 1) { return Err(ERR_INVALID_PARAM); }
        di = di + 1;
    }
    map_set(nodes, str_cstr(edge_node_id(node)), node);
    return Ok(edge_node_id(node));
}

fn edge_fleet_get(ef, id_cstr) { return map_get(load64(ef + 8), id_cstr); }
fn edge_fleet_node_count(ef) { return map_count(load64(ef + 8)); }

fn edge_fleet_heartbeat(ef, id_cstr, active_tasks, tasks_completed) {
    var node = map_get(load64(ef + 8), id_cstr);
    if (node == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    if (edge_node_status(node) == EDGE_DECOMMISSIONED) { return Err(ERR_INVALID_PARAM); }
    store64(node + 64, clock_epoch_secs());
    edge_node_set_status(node, EDGE_ONLINE);
    store64(node + 72, active_tasks);
    store64(node + 80, tasks_completed);
    return Ok(0);
}

fn edge_fleet_decommission(ef, id_cstr) {
    var node = map_get(load64(ef + 8), id_cstr);
    if (node == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    edge_node_set_status(node, EDGE_DECOMMISSIONED);
    return Ok(0);
}

fn edge_fleet_list(ef, status_filter) {
    var nodes = load64(ef + 8);
    var keys = map_keys(nodes);
    var result = vec_new();
    var i = 0;
    while (i < vec_len(keys)) {
        var node = map_get(nodes, vec_get(keys, i));
        if (status_filter < 0) { vec_push(result, node); }
        elif (edge_node_status(node) == status_filter) { vec_push(result, node); }
        i = i + 1;
    }
    return result;
}

fn edge_node_active_tasks(n) { return load64(n + 72); }

# --- IPC / message bus ---

enum MessageType { MSG_REQUEST = 0; MSG_RESPONSE = 1; MSG_EVENT = 2; MSG_HEARTBEAT = 3; MSG_COMMAND = 4; }

fn ipc_msg_new(source, target, msg_type, payload) {
    var m = alloc(48);
    store64(m, str_from_int(agent_next_id()));
    store64(m + 8, source);
    store64(m + 16, target);
    store64(m + 24, msg_type);
    store64(m + 32, payload);
    store64(m + 40, clock_epoch_secs());
    return m;
}

fn msg_bus_new() {
    var mb = alloc(16);
    store64(mb, map_new());
    store64(mb + 8, map_new());
    return mb;
}

fn msg_bus_subscribe(mb, agent_id_cstr) { map_set(load64(mb), agent_id_cstr, vec_new()); }
fn msg_bus_register_name(mb, name_cstr, agent_id_cstr) { map_set(load64(mb + 8), name_cstr, agent_id_cstr); }

fn msg_bus_publish(mb, msg) {
    var target = load64(msg + 16);
    var target_cstr = str_cstr(target);
    var subs = load64(mb);
    if (streq(target_cstr, "*") == 1) {
        var keys = map_keys(subs);
        var i = 0;
        while (i < vec_len(keys)) {
            var queue = map_get(subs, vec_get(keys, i));
            if (queue != 0) { vec_push(queue, msg); }
            i = i + 1;
        }
        return Ok(0);
    }
    var names = load64(mb + 8);
    var resolved = map_get(names, target_cstr);
    if (resolved != 0) {
        var queue = map_get(subs, resolved);
        if (queue != 0) { vec_push(queue, msg); }
        return Ok(0);
    }
    var queue = map_get(subs, target_cstr);
    if (queue != 0) { vec_push(queue, msg); }
    return Ok(0);
}

fn msg_bus_send_to_name(mb, name_cstr, msg) {
    var id = map_get(load64(mb + 8), name_cstr);
    if (id == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    var queue = map_get(load64(mb), id);
    if (queue == 0) { return Err(ERR_AGENT_NOT_FOUND); }
    vec_push(queue, msg);
    return Ok(0);
}

fn rpc_registry_new() {
    var rr = alloc(8);
    store64(rr, map_new());
    return rr;
}

fn rpc_register_method(rr, method_cstr, agent_id_cstr) { map_set(load64(rr), method_cstr, agent_id_cstr); }
fn rpc_find_handler(rr, method_cstr) { return map_get(load64(rr), method_cstr); }
fn rpc_list_methods(rr) { return map_keys(load64(rr)); }

# --- Federated vector store ---

enum VectorReplication { REPL_FULL = 0; REPL_PARTIAL = 1; REPL_SHARDED = 2; }

fn collection_replica_new(node_id, address, vector_count) {
    var cr = alloc(32);
    store64(cr, node_id);
    store64(cr + 8, address);
    store64(cr + 16, vector_count);
    store64(cr + 24, clock_epoch_secs());
    return cr;
}

fn replica_node_id(cr) { return load64(cr); }
fn replica_vector_count(cr) { return load64(cr + 16); }

fn fed_vstore_new(local_node_id, strategy) {
    var fvs = alloc(32);
    store64(fvs, local_node_id);
    store64(fvs + 8, map_new());
    store64(fvs + 16, strategy);
    store64(fvs + 24, 100);
    return fvs;
}

fn fed_vstore_local_id(fvs) { return load64(fvs); }
fn fed_vstore_strategy(fvs) { return load64(fvs + 16); }

fn fed_vstore_register_replica(fvs, collection_cstr, node_id, address, vector_count) {
    var colls = load64(fvs + 8);
    var replicas = map_get(colls, collection_cstr);
    if (replicas == 0) { replicas = vec_new(); map_set(colls, collection_cstr, replicas); }
    vec_push(replicas, collection_replica_new(node_id, address, vector_count));
}

fn fed_vstore_remove_node(fvs, node_id) {
    var colls = load64(fvs + 8);
    var fvk = map_keys(colls);
    var fvi = 0;
    while (fvi < vec_len(fvk)) {
        var replicas = map_get(colls, vec_get(fvk, fvi));
        if (replicas != 0) {
            var kept = vec_new();
            var fvri = 0;
            while (fvri < vec_len(replicas)) {
                var fvr = vec_get(replicas, fvri);
                if (str_eq(replica_node_id(fvr), node_id) == 0) { vec_push(kept, fvr); }
                fvri = fvri + 1;
            }
            map_set(colls, vec_get(fvk, fvi), kept);
        }
        fvi = fvi + 1;
    }
}

fn fed_vstore_remote_replicas(fvs, collection_cstr) {
    var replicas = map_get(load64(fvs + 8), collection_cstr);
    if (replicas == 0) { return vec_new(); }
    var local_id = load64(fvs);
    var remote = vec_new();
    var fvri = 0;
    while (fvri < vec_len(replicas)) {
        var fvr = vec_get(replicas, fvri);
        if (str_eq(replica_node_id(fvr), local_id) == 0) { vec_push(remote, fvr); }
        fvri = fvri + 1;
    }
    return remote;
}

fn fed_vstore_all_replicas(fvs, collection_cstr) {
    var replicas = map_get(load64(fvs + 8), collection_cstr);
    if (replicas == 0) { return vec_new(); }
    return replicas;
}

fn fed_vstore_collections(fvs) { return map_keys(load64(fvs + 8)); }
fn fed_vstore_collection_count(fvs) { return map_count(load64(fvs + 8)); }

fn remote_result_new(id, score, content, source_node) {
    var rr = alloc(32);
    store64(rr, id);
    store64(rr + 8, score);
    store64(rr + 16, content);
    store64(rr + 24, source_node);
    return rr;
}

fn remote_result_id(rr) { return load64(rr); }
fn remote_result_score(rr) { return load64(rr + 8); }

fn fed_vstore_merge_results(fvs, local_results, remote_batches, top_k) {
    var max_remote = load64(fvs + 24);
    var fv_all = vec_new();
    var fvli = 0;
    while (fvli < vec_len(local_results)) { vec_push(fv_all, vec_get(local_results, fvli)); fvli = fvli + 1; }
    var fvbi = 0;
    while (fvbi < vec_len(remote_batches)) {
        var fvbatch = vec_get(remote_batches, fvbi);
        var fvbri = 0;
        while (fvbri < vec_len(fvbatch)) {
            if (fvbri >= max_remote) { break; }
            vec_push(fv_all, vec_get(fvbatch, fvbri));
            fvbri = fvbri + 1;
        }
        fvbi = fvbi + 1;
    }
    var fv_dedup = map_new();
    var fvdi = 0;
    while (fvdi < vec_len(fv_all)) {
        var fvdr = vec_get(fv_all, fvdi);
        var fvdid = str_cstr(remote_result_id(fvdr));
        var fvde = map_get(fv_dedup, fvdid);
        if (fvde == 0) { map_set(fv_dedup, fvdid, fvdr); }
        else { if (f64_gt(remote_result_score(fvdr), remote_result_score(fvde)) == 1) { map_set(fv_dedup, fvdid, fvdr); } }
        fvdi = fvdi + 1;
    }
    var fv_dk = map_keys(fv_dedup);
    var fv_res = vec_new();
    var fvdki = 0;
    while (fvdki < vec_len(fv_dk)) { vec_push(fv_res, map_get(fv_dedup, vec_get(fv_dk, fvdki))); fvdki = fvdki + 1; }
    # Sort by score descending
    var fv_rn = vec_len(fv_res);
    var fvsi = 1;
    while (fvsi < fv_rn) {
        var fvsk = vec_get(fv_res, fvsi);
        var fvss = remote_result_score(fvsk);
        var fvsj = fvsi - 1;
        while (fvsj >= 0) {
            if (f64_gt(remote_result_score(vec_get(fv_res, fvsj)), fvss) == 1) { break; }
            vec_set(fv_res, fvsj + 1, vec_get(fv_res, fvsj));
            fvsj = fvsj - 1;
        }
        vec_set(fv_res, fvsj + 1, fvsk);
        fvsi = fvsi + 1;
    }
    var fv_final = vec_new();
    var fvfi = 0;
    while (fvfi < top_k) {
        if (fvfi >= vec_len(fv_res)) { break; }
        vec_push(fv_final, vec_get(fv_res, fvfi));
        fvfi = fvfi + 1;
    }
    return fv_final;
}

fn fed_vstore_stats(fvs) {
    var fvsk = map_keys(load64(fvs + 8));
    var fvs_tr = 0;
    var fvs_tv = 0;
    var fvs_ns = map_new();
    var fvski = 0;
    while (fvski < vec_len(fvsk)) {
        var fvsr = map_get(load64(fvs + 8), vec_get(fvsk, fvski));
        if (fvsr != 0) {
            var fvsri = 0;
            while (fvsri < vec_len(fvsr)) {
                var fvsrr = vec_get(fvsr, fvsri);
                fvs_tr = fvs_tr + 1;
                fvs_tv = fvs_tv + replica_vector_count(fvsrr);
                map_set(fvs_ns, str_cstr(replica_node_id(fvsrr)), 1);
                fvsri = fvsri + 1;
            }
        }
        fvski = fvski + 1;
    }
    var fvst = alloc(40);
    store64(fvst, vec_len(fvsk));
    store64(fvst + 8, fvs_tr);
    store64(fvst + 16, fvs_tv);
    store64(fvst + 24, map_count(fvs_ns));
    store64(fvst + 32, load64(fvs + 16));
    return fvst;
}

# --- RAG pipeline ---

fn rag_config_default() {
    var rc = alloc(40);
    store64(rc, 5);
    store64(rc + 8, 512);
    store64(rc + 16, 64);
    store64(rc + 24, f64_from(0));
    store64(rc + 32, str_from("template"));
    return rc;
}

fn rag_pipeline_new(config) {
    var rp = alloc(24);
    var vi = alloc(16);
    store64(vi, vec_new());
    store64(vi + 8, 0);
    store64(rp, vi);
    store64(rp + 8, config);
    store64(rp + 16, 1);
    return rp;
}

fn rag_ingest_text(rp, text, metadata) {
    var config = load64(rp + 8);
    var cs = load64(config + 8);
    var ov = load64(config + 16);
    var chunks = chunk_text(text, cs, ov);
    if (vec_len(chunks) == 0) { return vec_new(); }
    var ids = vec_new();
    var ci = 0;
    while (ci < vec_len(chunks)) {
        var id = load64(rp + 16);
        store64(rp + 16, id + 1);
        vec_push(ids, id);
        ci = ci + 1;
    }
    return ids;
}

fn rag_query_text(rp, query) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Context for: ");
    str_builder_add(sb, query);
    return str_builder_build(sb);
}

fn main() {
    alloc_init();

    # =============================================================
    # error — status mapping
    # =============================================================
    test_group("error");
    assert_eq(error_to_status(ERR_INVALID_PARAM), 400, "invalid_param -> 400");
    assert_eq(error_to_status(ERR_AGENT_NOT_FOUND), 404, "not_found -> 404");
    assert_eq(error_to_status(ERR_AGENT_EXISTS), 409, "exists -> 409");
    assert_eq(error_to_status(ERR_SUPERVISOR), 500, "supervisor -> 500");
    assert_eq(error_to_status(ERR_IPC), 500, "ipc -> 500");
    assert_eq(error_to_status(ERR_SCHEDULER), 500, "scheduler -> 500");
    assert_eq(error_to_status(ERR_FEDERATION), 500, "federation -> 500");
    assert_eq(error_to_status(ERR_API), 500, "api -> 500");
    assert_eq(error_to_status(ERR_STORAGE), 500, "storage -> 500");

    # =============================================================
    # config — defaults and modification
    # =============================================================
    test_group("config");
    var cfg = config_new();
    assert_eq(config_port(cfg), 8090, "default port");
    assert_eq(config_max_agents(cfg), 1000, "default max_agents");
    assert(str_eq(config_listen_addr(cfg), str_from("127.0.0.1")) == 1, "default listen_addr");
    assert(str_eq(config_data_dir(cfg), str_from("/var/lib/agnos")) == 1, "default data_dir");

    config_set_port(cfg, 9090);
    assert_eq(config_port(cfg), 9090, "modified port");

    # =============================================================
    # agent — creation and state
    # =============================================================
    test_group("agent");
    var a1 = agent_handle_new(1, str_from("test-agent"));
    assert_eq(agent_id(a1), 1, "agent id");
    assert(str_eq(agent_name(a1), str_from("test-agent")) == 1, "agent name");
    assert_eq(agent_status(a1), AGENT_PENDING, "initial status pending");
    assert_eq(agent_pid(a1), 0, "no pid initially");

    # Unique IDs
    var a2 = agent_handle_new(agent_next_id(), str_from("agent-2"));
    var a3 = agent_handle_new(agent_next_id(), str_from("agent-3"));
    assert(agent_id(a2) != agent_id(a3), "unique agent ids");

    # Status transitions
    agent_set_status(a1, AGENT_RUNNING);
    assert_eq(agent_status(a1), AGENT_RUNNING, "set running");
    agent_set_status(a1, AGENT_STOPPED);
    assert_eq(agent_status(a1), AGENT_STOPPED, "set stopped");

    # All status values representable
    var si = 0;
    while (si <= 6) {
        agent_set_status(a1, si);
        assert_eq(agent_status(a1), si, "status value");
        si = si + 1;
    }

    # =============================================================
    # /proc helpers — edge cases
    # =============================================================
    test_group("proc_helpers");

    # Nonexistent/zero PID returns safe defaults
    assert_eq(read_vm_rss(0), 0, "rss pid 0");
    assert_eq(count_fds(0), 0, "fds pid 0");
    assert_eq(count_threads(0), 1, "threads pid 0 default 1");

    # Bogus PID returns safe defaults
    assert_eq(read_vm_rss(999999999), 0, "rss bogus pid");
    assert_eq(count_fds(999999999), 0, "fds bogus pid");
    assert_eq(count_threads(999999999), 1, "threads bogus pid");

    # =============================================================
    # circuit breaker
    # =============================================================
    test_group("circuit_breaker");

    # Starts closed
    var cb = cb_new(3, 10000, 2);
    assert_eq(cb_state(cb), CB_CLOSED, "starts closed");
    assert_eq(cb_failure_count(cb), 0, "no failures");
    assert_eq(cb_can_execute(cb), 1, "can execute when closed");

    # Opens after threshold
    cb_record_failure(cb);
    cb_record_failure(cb);
    assert_eq(cb_state(cb), CB_CLOSED, "still closed at 2");
    cb_record_failure(cb);
    assert_eq(cb_state(cb), CB_OPEN, "opens at 3");
    assert_eq(cb_can_execute(cb), 0, "blocked when open");

    # Success resets failure count
    var cb2 = cb_new(5, 10000, 1);
    cb_record_failure(cb2);
    cb_record_failure(cb2);
    assert_eq(cb_failure_count(cb2), 2, "failure count 2");
    cb_record_success(cb2);
    assert_eq(cb_failure_count(cb2), 0, "reset on success");

    # Half-open transition (0ms timeout = immediate)
    var cb3 = cb_new(1, 0, 1);
    cb_record_failure(cb3);
    assert_eq(cb_state(cb3), CB_OPEN, "open after 1 failure");
    assert_eq(cb_can_execute(cb3), 1, "transitions to half-open");
    assert_eq(cb_state(cb3), CB_HALF_OPEN, "now half-open");

    # Closes after half-open successes
    var cb4 = cb_new(1, 0, 2);
    cb_record_failure(cb4);
    cb_can_execute(cb4);  # -> half-open
    cb_record_success(cb4);
    assert_eq(cb_state(cb4), CB_HALF_OPEN, "still half-open at 1 success");
    cb_record_success(cb4);
    assert_eq(cb_state(cb4), CB_CLOSED, "closed after 2 successes");

    # Re-opens on half-open failure
    var cb5 = cb_new(1, 0, 3);
    cb_record_failure(cb5);
    cb_can_execute(cb5);  # -> half-open
    cb_record_failure(cb5);
    assert_eq(cb_state(cb5), CB_OPEN, "re-opened from half-open");

    # Reset
    cb_reset(cb);
    assert_eq(cb_state(cb), CB_CLOSED, "reset to closed");
    assert_eq(cb_failure_count(cb), 0, "reset failure count");

    # =============================================================
    # output capture — ring buffer
    # =============================================================
    test_group("output_capture");

    var oc = output_capture_new(3);
    assert_eq(output_capture_len(oc), 0, "empty initially");

    output_capture_push(oc, OUT_STDOUT, str_from("line1"));
    output_capture_push(oc, OUT_STDERR, str_from("line2"));
    output_capture_push(oc, OUT_STDOUT, str_from("line3"));
    assert_eq(output_capture_len(oc), 3, "3 lines");

    # Ring buffer eviction
    output_capture_push(oc, OUT_STDOUT, str_from("line4"));
    output_capture_push(oc, OUT_STDOUT, str_from("line5"));
    assert_eq(output_capture_len(oc), 3, "ring at capacity");
    # First line should be line3 now
    var lines = load64(oc);
    var first = vec_get(lines, 0);
    assert(str_eq(load64(first + 16), str_from("line3")) == 1, "oldest is line3");

    # =============================================================
    # memory — key validation and sanitization
    # =============================================================
    test_group("memory_key_validation");

    assert(is_ok(validate_key(str_from("my-key"))) == 1, "valid key");
    assert(is_ok(validate_key(str_from("key_123"))) == 1, "valid key_123");
    assert(is_ok(validate_key(str_from("a"))) == 1, "valid single char");
    assert(is_err_result(validate_key(str_from(""))) == 1, "empty key rejected");
    assert(is_err_result(validate_key(str_from("../etc/passwd"))) == 1, "traversal rejected");
    assert(is_err_result(validate_key(str_from("foo/bar"))) == 1, "slash rejected");
    assert(is_err_result(validate_key(str_from("foo\\bar"))) == 1, "backslash rejected");
    assert(is_err_result(validate_key(str_from(".."))) == 1, "dotdot rejected");

    # Key too long
    var long_sb = str_builder_new();
    var li = 0;
    while (li < 260) { str_builder_add_cstr(long_sb, "x"); li = li + 1; }
    assert(is_err_result(validate_key(str_builder_build(long_sb))) == 1, "too-long rejected");

    test_group("memory_key_sanitization");
    assert(str_eq(sanitize_key(str_from("hello-world")), str_from("hello-world")) == 1, "hyphen preserved");
    assert(str_eq(sanitize_key(str_from("key_123")), str_from("key_123")) == 1, "underscore preserved");
    assert(str_eq(sanitize_key(str_from("has spaces")), str_from("has_spaces")) == 1, "spaces replaced");
    assert(str_eq(sanitize_key(str_from("path/traversal")), str_from("path_traversal")) == 1, "slash replaced");

    # =============================================================
    # vector store — cosine similarity
    # =============================================================
    test_group("cosine_similarity");

    # Identical vectors → similarity 1.0
    var v1 = alloc(24);
    store64(v1, f64_from(1));
    store64(v1 + 8, f64_from(2));
    store64(v1 + 16, f64_from(3));
    var sim = cosine_similarity(v1, v1, 3);
    var diff = f64_sub(sim, f64_from(1));
    if (f64_lt(diff, f64_from(0)) == 1) { diff = f64_sub(f64_from(0), diff); }
    assert(f64_lt(diff, f64_div(f64_from(1), f64_from(1000000))) == 1, "identical vectors ~1.0");

    # Orthogonal vectors → similarity 0.0
    var orth_a = alloc(16);
    var orth_b = alloc(16);
    store64(orth_a, f64_from(1));
    store64(orth_a + 8, f64_from(0));
    store64(orth_b, f64_from(0));
    store64(orth_b + 8, f64_from(1));
    var sim_orth = cosine_similarity(orth_a, orth_b, 2);
    var abs_orth = sim_orth;
    if (f64_lt(abs_orth, f64_from(0)) == 1) { abs_orth = f64_sub(f64_from(0), abs_orth); }
    assert(f64_lt(abs_orth, f64_div(f64_from(1), f64_from(1000000))) == 1, "orthogonal ~0.0");

    # Zero dimension → 0.0
    assert_eq(cosine_similarity(v1, v1, 0), f64_from(0), "dim 0 -> 0");

    # Zero vector → 0.0
    var zero = alloc(16);
    store64(zero, f64_from(0));
    store64(zero + 8, f64_from(0));
    assert_eq(cosine_similarity(zero, orth_a, 2), f64_from(0), "zero vec -> 0");

    # =============================================================
    # RAG — text chunking
    # =============================================================
    test_group("chunk_text");

    var chunks = chunk_text(str_from("abcdefgh"), 4, 0);
    assert_eq(vec_len(chunks), 2, "no overlap: 2 chunks");
    assert(str_eq(vec_get(chunks, 0), str_from("abcd")) == 1, "chunk 0 = abcd");
    assert(str_eq(vec_get(chunks, 1), str_from("efgh")) == 1, "chunk 1 = efgh");

    var chunks2 = chunk_text(str_from("abcdefgh"), 4, 2);
    assert_eq(vec_len(chunks2), 4, "overlap 2: 4 chunks");
    assert(str_eq(vec_get(chunks2, 0), str_from("abcd")) == 1, "overlap chunk 0");
    assert(str_eq(vec_get(chunks2, 1), str_from("cdef")) == 1, "overlap chunk 1");

    assert_eq(vec_len(chunk_text(str_from(""), 10, 0)), 0, "empty text");
    assert_eq(vec_len(chunk_text(str_from("hello"), 0, 0)), 0, "zero chunk size");
    assert_eq(vec_len(chunk_text(str_from("hi"), 100, 0)), 1, "chunk > text");

    # =============================================================
    # tokenizer
    # =============================================================
    test_group("tokenize");

    var toks = tokenize(str_from("Hello, World! Test-123."));
    assert_eq(vec_len(toks), 4, "4 tokens");
    assert(str_eq(vec_get(toks, 0), str_from("hello")) == 1, "lowercased hello");
    assert(str_eq(vec_get(toks, 1), str_from("world")) == 1, "lowercased world");
    assert(str_eq(vec_get(toks, 2), str_from("test")) == 1, "test");
    assert(str_eq(vec_get(toks, 3), str_from("123")) == 1, "123");

    assert_eq(vec_len(tokenize(str_from(""))), 0, "empty tokens");

    # =============================================================
    # scheduler — state machine transitions
    # =============================================================
    test_group("scheduler_transitions");

    # Build a minimal task (72 bytes, status at offset 40)
    var task = alloc(72);
    store64(task + 40, TASK_QUEUED);

    # Valid transitions
    assert(is_ok(sched_task_transition(task, TASK_SCHEDULED)) == 1, "queued -> scheduled");
    assert(is_ok(sched_task_transition(task, TASK_RUNNING)) == 1, "scheduled -> running");
    assert(is_ok(sched_task_transition(task, TASK_COMPLETED)) == 1, "running -> completed");

    # Invalid transition
    store64(task + 40, TASK_COMPLETED);
    assert(is_err_result(sched_task_transition(task, TASK_RUNNING)) == 1, "completed -> running invalid");

    # Preemption path
    store64(task + 40, TASK_RUNNING);
    assert(is_ok(sched_task_transition(task, TASK_PREEMPTED)) == 1, "running -> preempted");
    assert(is_ok(sched_task_transition(task, TASK_QUEUED)) == 1, "preempted -> queued");

    # Cancel from any active state
    store64(task + 40, TASK_QUEUED);
    assert(is_ok(sched_task_transition(task, TASK_CANCELLED)) == 1, "queued -> cancelled");

