    rpc_register_method(rpc, "fetch", "agent-2");
    assert(rpc_find_handler(rpc, "calculate") != 0, "find calculate");
    assert(rpc_find_handler(rpc, "fetch") != 0, "find fetch");
    assert_eq(rpc_find_handler(rpc, "missing"), 0, "missing method");

    var rpc_methods = rpc_list_methods(rpc);
    assert_eq(vec_len(rpc_methods), 2, "2 methods");

