    assert_eq(vec_len(iq2), 1, "agent-2 got broadcast");

    var imsg2 = ipc_msg_new(str_from("sys"), str_from("x"), MSG_COMMAND, str_from("cmd"));
    msg_bus_send_to_name(bus, "worker", imsg2);
    assert_eq(vec_len(iq1), 2, "agent-1 got named msg");
    assert_eq(vec_len(iq2), 1, "agent-2 unchanged");

    var rpc = rpc_registry_new();
