    # =============================================================
    # edge fleet — full lifecycle
    # =============================================================
    test_group("edge_lifecycle");

    var efleet = edge_fleet_new(edge_fleet_config_default());
    var enode = edge_node_new(str_from("edge-a"), str_from("x86_64"), 4, 4096);
    var ereg = edge_fleet_register(efleet, enode);
    assert(is_ok(ereg) == 1, "register ok");
    assert_eq(edge_fleet_node_count(efleet), 1, "1 edge node");

    var en_bad = edge_node_new(str_from(""), str_from("x86_64"), 4, 4096);
    assert(is_err_result(edge_fleet_register(efleet, en_bad)) == 1, "empty name rejected");

    var en_dup = edge_node_new(str_from("edge-a"), str_from("x86_64"), 4, 4096);
    assert(is_err_result(edge_fleet_register(efleet, en_dup)) == 1, "duplicate rejected");

    var eid_cstr = str_cstr(payload(ereg));
    var ehb = edge_fleet_heartbeat(efleet, eid_cstr, 5, 20);
    assert(is_ok(ehb) == 1, "heartbeat ok");

    var edc = edge_fleet_decommission(efleet, eid_cstr);
    assert(is_ok(edc) == 1, "decommission ok");
    var enode_after = edge_fleet_get(efleet, eid_cstr);
    assert_eq(edge_node_status(enode_after), EDGE_DECOMMISSIONED, "decommissioned status");

    assert(is_err_result(edge_fleet_heartbeat(efleet, eid_cstr, 0, 0)) == 1, "heartbeat after decomm fails");

    var eall = edge_fleet_list(efleet, 0 - 1);
    assert_eq(vec_len(eall), 1, "list all = 1");
    var eonline = edge_fleet_list(efleet, EDGE_ONLINE);
    assert_eq(vec_len(eonline), 0, "no online nodes");
    var edecomm = edge_fleet_list(efleet, EDGE_DECOMMISSIONED);
    assert_eq(vec_len(edecomm), 1, "1 decommissioned");

