    # =============================================================
    # node capacity — resource fitting
    # =============================================================
    test_group("node_capacity");

    var nc1 = node_cap_new(str_from("n1"), 8, 16384, 102400, 0);
    assert(str_eq(node_cap_id(nc1), str_from("n1")) == 1, "node id");
    assert_eq(node_cap_can_fit(nc1, 4, 8192, 0), 1, "fits under capacity");
    assert_eq(node_cap_can_fit(nc1, 16, 8192, 0), 0, "rejects over cpu");
    assert_eq(node_cap_can_fit(nc1, 4, 32768, 0), 0, "rejects over mem");
    assert_eq(node_cap_utilization(nc1), 0, "zero utilization initially");

    node_cap_reserve(nc1, 4, 8192, 0);
    assert_eq(node_cap_avail_cpu(nc1), 4, "avail cpu after reserve");
    assert_eq(node_cap_avail_mem(nc1), 8192, "avail mem after reserve");
    assert_eq(node_cap_utilization(nc1), 50, "50% utilization");

    node_cap_release(nc1, 4, 8192, 0);
    assert_eq(node_cap_avail_cpu(nc1), 8, "restored cpu");
    assert_eq(node_cap_avail_mem(nc1), 16384, "restored mem");

